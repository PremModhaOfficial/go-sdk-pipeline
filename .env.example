# SDK Target — MUST be a git repo
SDK_TARGET_DIR=/path/to/motadata-go-sdk/src/motadatagosdk

# Archive — read-only reference for ported agents/skills

# Test backend credentials (integration tests)
# Use fake values here; real values go in .env (gitignored)
DRAGONFLY_ADDR=localhost:6379
DRAGONFLY_PASSWORD=fake
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=fake
S3_SECRET_KEY=fake
KAFKA_BROKERS=localhost:9092

# Pipeline runtime
PIPELINE_VERSION=0.1.0

# MCP server env — referenced by .mcp.json
# exa requires a real API key (get one at https://exa.ai); do NOT commit the real value
EXA_API_KEY=
# Neo4j creds default to the local claude-neo4j container (neo4j/neo4jneo4j on bolt://localhost:7687).
# Override here only if your local Neo4j is configured differently.
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=neo4jneo4j
