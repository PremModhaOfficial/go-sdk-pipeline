# §6. motadata_py_sdk.events.stores  (TPRD §8)
# ============================================================================
"""KV + Object Store wrappers + optional tenant overlays.
[traces-to: TPRD-§8-Module-events-stores]
[constraint: wire-exact bench/N/A]  -- delegates to nats-py;
nats-py upstream defines wire bytes.
"""
from typing import AsyncIterator, Iterable

@dataclass
class KeyValueConfig:
    """[traces-to: TPRD-§8.1-KeyValueConfig]

    __post_init__ validation (CONV-5 fix, D3 iter 3): bucket regex, history
    bounded [1, 64] per nats-py upstream limit, non-negative ttl/max_bytes,
    description length cap. `max_value_size = -1` is the documented sentinel
    for 'inherit server default' so it is permitted; values < -1 are rejected.
    """
    bucket: str
    description: str = ""
    max_value_size: int = -1
    history: int = 1
    ttl: float = 0.0
    max_bytes: int = 0
    storage: StorageType = StorageType.FILE
    replicas: int = 1
    compression: bool = False

    def __post_init__(self) -> None:
        if not self.bucket or not _BUCKET_NAME_REGEX.match(self.bucket):
            raise ValidationError(
                f"KeyValueConfig.bucket must be non-empty and match {_BUCKET_NAME_REGEX.pattern!r}; got {self.bucket!r}"
            )
        if self.max_value_size < -1:
            raise ValidationError(
                f"KeyValueConfig.max_value_size must be >= -1 (-1 = server default); got {self.max_value_size}"
            )
        if not (1 <= self.history <= 64):
            raise ValidationError(
                f"KeyValueConfig.history must be in [1, 64]; got {self.history}"
            )
        if self.ttl < 0:
            raise ValidationError(f"KeyValueConfig.ttl must be >= 0; got {self.ttl}")
        if self.max_bytes < 0:
            raise ValidationError(f"KeyValueConfig.max_bytes must be >= 0; got {self.max_bytes}")
        if self.replicas not in (1, 3, 5):
            raise ValidationError(f"KeyValueConfig.replicas must be 1, 3, or 5; got {self.replicas}")
        if len(self.description) > _MAX_DESCRIPTION_LEN:
            raise ValidationError(
                f"KeyValueConfig.description length must be <= {_MAX_DESCRIPTION_LEN}; got {len(self.description)}"
            )

@dataclass(frozen=True, slots=True)
class KeyValueEntry:
    """[traces-to: TPRD-§8.1-KeyValueEntry]"""
    bucket: str
    key: str
    value: bytes
    revision: int
    delta: int
    operation: str  # 'PUT' | 'DELETE' | 'PURGE'
    created: datetime

# Sentinel exceptions (extend events.utils sentinels)
class ErrKeyNotFound(EventsError): pass
class ErrKeyExists(EventsError): pass
class ErrInvalidKey(EventsError): pass
class ErrHistoryToLarge(EventsError): pass

