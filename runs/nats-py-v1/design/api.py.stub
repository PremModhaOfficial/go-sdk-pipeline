    def intercept_subscribe(self) -> SubscribeMiddleware: ...

# --- 7.6 Logging ---
class LogLevel(Enum):
    """[traces-to: TPRD-§9.6-LogLevel]"""
    DEBUG = 0
    INFO = 1
    WARN = 2
    ERROR = 3

class LoggingMiddleware:
    """[traces-to: TPRD-§9.6-LoggingMiddleware]
    [constraint: p50_intercept_publish_payload_off <= 4us | bench/bench_middleware_logging_publish]

    Per-call fields (byte-exact keys):
      subject, msg_id (from headers['Nats-Msg-Id']), size (len(msg.data)),
      latency_ms (publish only) | process_time_ms (subscribe only),
      error (string, on failure),
      payload (only when log_payload=True, truncated to max_payload_size with '...' suffix),
      trace_id, span_id (from get_trace_context() if present),
      tenant_id (from get_tenant_id() if present).

    Log messages (byte-exact):
      Publish pre:    DEBUG 'publishing message'
      Publish ok:     INFO  'message published'
      Publish err:    ERROR 'publish failed'
      Subscribe pre:  DEBUG 'processing message'
      Subscribe ok:   DEBUG 'message processed'   (NOT INFO — by design quiet)
      Subscribe err:  ERROR 'message processing failed'

    Logging never short-circuits — always calls next, returns its err verbatim.
    """
    def __init__(self, logger: Any) -> None: ...
    def with_level(self, level: LogLevel) -> "LoggingMiddleware": ...
    def with_payload(self, enabled: bool, max_size: int = 1024) -> "LoggingMiddleware": ...
    def intercept_publish(self) -> PublishMiddleware: ...
    def intercept_subscribe(self) -> SubscribeMiddleware: ...

# --- 7.7 Tracing ---
class TracingMiddleware:
    """[traces-to: TPRD-§9.7-TracingMiddleware]
    [constraint: p50_intercept_publish <= 35us | bench/bench_middleware_tracing_publish]

    OTel mode publish (publish_with_otel) — TPRD §15.28 attrs applied:
      1. Span tracer.start_producer(ctx, 'events.publish',
         attrs={'messaging.system': 'nats', 'messaging.destination': <subject>,
                'messaging.operation': 'publish'}).
      2. Read active OTel SpanContext; if valid, build TraceContext{trace_id,
         span_id, sampled} and store in ctx.
      3. ensure_headers(msg); core.extract_headers(msg.headers).
      4. next(ctx, msg). span.set_error(err) or span.set_ok(). span.end().

    OTel mode subscribe (FIX per TPRD §15.30 — propagator.extract restored at
    H5-rev-3 D3 iter 2; Q5 revocation reversed):
      1. Headers carry W3C `traceparent` from the producer (set by step 4 of
         publish above via OTel SDK's TextMapPropagator.inject inside the
         span context manager). On the consumer side we MUST extract the
         producer trace context BEFORE opening the consumer span so that
         start_consumer takes the remote-parent and the consumer span is
         linked into the producer trace.
      2. Build a NatsHeaderGetter carrier from msg.headers (per the
         python-otel-instrumentation skill — read-only dict-of-str-to-str
         adapter that returns [] for missing keys).
      3. parent_ctx = propagator.extract(carrier=NatsHeaderGetter(msg.headers))
         — uses the global TextMapPropagator (W3C tracecontext + baggage by
         default, configurable via TracerInitConfig.propagators).
      4. If headers also carry the legacy non-W3C trace headers (X-Trace-ID,
         X-B3-*), call core.inject_context(msg.headers) to restash into our
         ContextVars (logs still want the legacy keys).
      5. tracer.start_consumer(parent_ctx, 'events.receive',
         attrs={'messaging.system': 'nats',
                'messaging.destination': <subject>,
                'messaging.operation': 'receive',
                'messaging.operation.name': 'receive'}). Span IS linked to
         producer trace via parent_ctx.
      6. Read active span; re-stash into core.TraceContext for downstream logs.
      7. next. Set status. End.

    Span names (byte-exact, mirror INV-5):
      Producer: 'events.publish'   Consumer: 'events.receive'

    Span attribute keys (byte-exact, with TPRD §15.28 messaging.* additions):
      messaging.system='nats'                 (FIX §15.28 — added on every span)
      messaging.destination=<subject>         (mirror Go; NOT messaging.destination.name)
      messaging.operation='publish'|'receive'|'process' (FIX §15.28 — added)
    """
    def __init__(self, *,
                 tracer: Any | None = None,
                 use_otel: bool = True,
                 sampler: Callable[[], bool] | None = None) -> None: ...
    def intercept_publish(self) -> PublishMiddleware: ...
    def intercept_subscribe(self) -> SubscribeMiddleware: ...

def extract_w3c_traceparent(s: str) -> TraceContext | None:
    """Parse 'version-traceID-parentID-flags'. Returns None if len(s) < 55 OR
    split count != 4. [traces-to: TPRD-§9.7-extract-w3c-traceparent]
    """
    ...

def format_w3c_traceparent(tc: TraceContext | None) -> str:
    """'00-{trace_id}-{span_id}-01' if sampled else '...-00'.
    Returns '' if tc is None, trace_id == '', or span_id == ''.
    [traces-to: TPRD-§9.7-format-w3c-traceparent]
