# --- 8.4 motadata_py_sdk.otel.logger ---
@dataclass(frozen=True, slots=True)
class LoggerInitConfig:
    """[traces-to: TPRD-§10-LoggerInitConfig §15.31 §SEMVER-4 §CONV-2]

