# --- 8.3 motadata_py_sdk.otel.metrics ---
@dataclass(frozen=True, slots=True)
class MetricsInitConfig:
    """[traces-to: TPRD-§10-MetricsInitConfig §15.31 §SEMVER-3 §SEMVER-4 §CONV-2]

