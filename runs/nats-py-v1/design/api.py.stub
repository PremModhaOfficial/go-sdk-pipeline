    `export_interval` default unified at 15.0s per SEMVER-3 (matches
    OTEL_DEFAULT_EXPORT_INTERVAL); validation in `__post_init__` per §15.31.
    """
    service: ServiceInfo
    enabled: bool = True
    otel_enabled: bool = False
    otel_endpoint: str = "localhost:4317"
    otel_insecure: bool = True
    otel_protocol: _Literal["grpc", "http", "http/protobuf"] = "grpc"
    export_interval: float = 15.0  # OTel-spec recommended; matches OTEL_DEFAULT_EXPORT_INTERVAL
    default_labels: dict[str, str] = field(default_factory=dict)

    def __post_init__(self) -> None:
        """Runtime validation per TPRD §15.31 (FIX — pre-authorized; H5-rev-3
        D3 iter 2).

        Raises:
            ValidationError: if any of:
              - service.name is blank
              - export_interval <= 0
              - otel_protocol not in {'grpc','http','http/protobuf'}
              - otel_endpoint is blank when (enabled and otel_enabled)
              - default_labels contains keys with leading/trailing whitespace
        """
        ...

async def init_metrics(cfg: MetricsInitConfig) -> ShutdownCollector:
    """Initialize MeterProvider; periodic exporter at export_interval (default 15s).
    Resource attrs from ServiceInfo. Returns ShutdownCollector.
