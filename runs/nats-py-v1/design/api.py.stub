# --- 8.5 Default batch/queue settings (§10.8) ---
OTEL_DEFAULT_MAX_QUEUE_SIZE: Final[int] = 2048
OTEL_DEFAULT_MAX_EXPORT_BATCH: Final[int] = 512
# OTel-spec recommended default for production PeriodicExportingMetricReader
# (15 seconds). Was 1.0 prior to H5-rev-3 D3 iter 2; SEMVER-3 fix unified all
# three sites (constant + MetricsInitConfig.export_interval +
# _MetricsConfig.export_interval_seconds) on 15.0.
OTEL_DEFAULT_EXPORT_INTERVAL: Final[float] = 15.0
OTEL_DEFAULT_BATCH_TIMEOUT: Final[float] = 30.0
OTEL_DEFAULT_SHUTDOWN_TIMEOUT: Final[float] = 10.0


# ============================================================================
# §9. motadata_py_sdk.config  (TPRD §11)
# ============================================================================
"""pydantic-settings v2 unified config tree.

Env-var precedence: defaults → YAML → env (env wins).
Both Go-style flat env (LOG_LEVEL, METRICS_OTEL_ENDPOINT) AND OTel-standard
env (OTEL_EXPORTER_OTLP_ENDPOINT, OTEL_SERVICE_NAME) accepted via
AliasChoices on each field.

[traces-to: TPRD-§11-Module-config]
"""
from typing import Annotated, Literal
# pydantic + pydantic_settings imports deferred to runtime.

# --- 9.1 Sub-models ---
# CONV-3 fix (H5-rev-3 D3 iter 2): leading underscore dropped from all 9
# pydantic sub-model names. They are PUBLIC re-exports from
# `motadata_py_sdk.config.__init__`; the prior `_<Name>` style implied
# private-by-convention which contradicted the public re-export. CONV-4 fix
# applied: mutable literal defaults (`[]`, `{}`) replaced with
# `Field(default_factory=...)` to defeat the shared-instance footgun.
# (`pydantic.Field` import deferred to runtime; shown as `Field(...)` below.)

class ServiceConfig:  # pydantic.BaseModel at impl time
    """[traces-to: TPRD-§11.3-ServiceConfig]"""
    name: str = "app"                  # env: SERVICE_NAME, OTEL_SERVICE_NAME
    version: str = "0.0.0"             # env: SERVICE_VERSION
    environment: str = "development"   # env: SERVICE_ENVIRONMENT

class TracerConfig:  # pydantic.BaseModel
    """[traces-to: TPRD-§11.3-TracerConfig]"""
    enabled: bool = False
    otel_endpoint: str = "localhost:4317"
    otel_insecure: bool = True
    otel_protocol: Literal["grpc", "http", "http/protobuf"] = "grpc"
    otel_debug: bool = False
    sampling_ratio: Annotated[float, "ge=0.0, le=1.0"] = 1.0
    # CONV-4 fix: was `propagators: list[str] = ["tracecontext", "baggage"]`
    # — mutable default = shared instance across all model instances. Now
    # uses Field(default_factory=lambda: [...]).
    propagators: list[str] = "Field(default_factory=lambda: ['tracecontext', 'baggage'])"  # type: ignore[assignment]
    batch_timeout_seconds: float = 5.0
    max_export_batch: int = 512
    max_queue_size: int = 2048

class ReconnectConfig:  # pydantic.BaseModel
    """[traces-to: TPRD-§11.1-ReconnectConfig]"""
    max_attempts: int = -1
    initial_interval_seconds: Annotated[float, "gt=0"] = 0.1
    max_interval_seconds: float = 30.0  # validator: >= initial_interval_seconds
    multiplier: Annotated[float, "ge=1.0"] = 2.0
    jitter: Annotated[float, "ge=0.0, le=1.0"] = 0.1

class TLSConfig:  # pydantic.BaseModel
    """[traces-to: TPRD-§11.1-TLSConfig]"""
    enabled: bool = False
    cert_file: str = ""
    key_file: str = ""
    ca_file: str = ""
    skip_verify: bool = False
    # @model_validator(mode='after') enforces (per TPRD §15.31 alignment):
    #   if enabled: cert+key both empty OR both set
    #              + if any of cert/key/ca set, file MUST exist (FileExistsError)

class StreamSubConfig:  # pydantic.BaseModel
    """[traces-to: TPRD-§11.1-Stream]"""
    enabled: bool = True              # env: EVENTS_STREAM_DISABLED (INVERTED)
    domain: str = ""
    prefix: str = ""

class EventsConfig:  # pydantic.BaseModel
    """[traces-to: TPRD-§11.1-EventsConfig]"""
    # CONV-4 fix: mutable list default replaced with Field(default_factory=...)
    servers: list[str] = "Field(default_factory=lambda: ['nats://localhost:4222'])"  # type: ignore[assignment]
    name: str = ""
    connect_timeout_seconds: Annotated[float, "gt=0"] = 10.0
    drain_timeout_seconds: Annotated[float, "gt=0"] = 30.0
    idle_timeout_seconds: Annotated[float, "gt=0"] = 1800.0
    cleanup_interval_seconds: Annotated[float, "gt=0"] = 60.0
    tls: TLSConfig
    reconnect: ReconnectConfig
    stream: StreamSubConfig

class LoggerConfig:  # pydantic.BaseModel; mirrors §11.3 logger keys
    """[traces-to: TPRD-§11.3-LoggerConfig]"""
    level: Literal["debug", "info", "warn", "error"] = "info"
    console_enabled: bool = True
    console_format: Literal["json", "console"] = "json"
    otel_enabled: bool = False
    otel_endpoint: str = "localhost:4317"
    otel_insecure: bool = True
    otel_protocol: Literal["grpc", "http", "http/protobuf"] = "grpc"
    otel_debug: bool = False
    file_enabled: bool = False
    file_path: str = "logs/app.log"
    file_max_size_mb: int = 100
    file_max_backups: int = 5
    file_max_age_days: int = 7
    file_compress: bool = True
    add_caller: bool = True
    caller_skip: int = 2
    # CONV-4 fix: mutable dict default replaced with Field(default_factory=dict)
    module_levels: dict[str, str] = "Field(default_factory=dict)"  # type: ignore[assignment]

class MetricsConfig:  # pydantic.BaseModel
    """[traces-to: TPRD-§11.3-MetricsConfig]"""
    enabled: bool = True
    otel_enabled: bool = False
    otel_endpoint: str = "localhost:4317"
    otel_insecure: bool = True
    otel_protocol: Literal["grpc", "http", "http/protobuf"] = "grpc"
    # SEMVER-3 fix: 15.0 unified across constant + InitConfig +
    # _MetricsConfig.export_interval_seconds (was already 15.0 here; constant
    # was 1.0 — now 15.0).
    export_interval_seconds: float = 15.0
    # CONV-4 fix: mutable dict default replaced with Field(default_factory=dict)
    default_labels: dict[str, str] = "Field(default_factory=dict)"  # type: ignore[assignment]

class PublishConfig:  # mirrors §11.2
    """[traces-to: TPRD-§11.2]"""
    retry_max_attempts: int = 3
    retry_initial_interval_seconds: float = 0.1
    retry_max_interval_seconds: float = 5.0
    retry_multiplier: float = 2.0
    retry_jitter: float = 0.1
    ack_timeout_seconds: float = 5.0
    enable_deduplication: bool = True
    deduplication_window_seconds: float = 120.0

class SubscribeConfig:  # mirrors §11.2
    """[traces-to: TPRD-§11.2]"""
    queue_group: str = ""
    max_concurrent: Annotated[int, "gt=0"] = 10
    ack_wait_seconds: Annotated[float, "gt=0"] = 30.0
    batch_size: int = 100
    batch_wait_seconds: float = 0.1

class Settings:  # pydantic_settings.BaseSettings
    """Top-level. [traces-to: TPRD-§11.6-Settings]
    [constraint: p50_construct_env_only <= 5000us | bench/bench_config_settings_env_cold]

    model_config = SettingsConfigDict(
        env_nested_delimiter='__',
        env_file='.env',
        extra='ignore',
        env_file_encoding='utf-8',
    )

    Field aliases per §11.3 mapping (Go-style flat env names + OTel-standard):
      service.name → AliasChoices('SERVICE_NAME', 'OTEL_SERVICE_NAME')
      tracer.otel_endpoint → AliasChoices('TRACER_OTEL_ENDPOINT', 'OTEL_EXPORTER_OTLP_ENDPOINT')
      logger.level → AliasChoices('LOG_LEVEL')
      etc. Custom EnvSettingsSource may be needed for the inverted
      EVENTS_STREAM_DISABLED → events.stream.enabled mapping.
    """
    service: ServiceConfig
    tracer: TracerConfig
    events: EventsConfig
    logger: LoggerConfig
    metrics: MetricsConfig
    publish: PublishConfig
    subscribe: SubscribeConfig

# Loader functions (§11.4)
def load(*, dir: str | None = None, env: str | None = None) -> Settings:
    """Load with precedence: defaults → YAML → env.
    If dir given: read <dir>/config.yaml; if env given: also <dir>/config.<env>.yaml.
    YAML env-var expansion (os.path.expandvars-equivalent) before parsing.

    SECURITY: YAML parsing uses `yaml.safe_load()` ONLY. NEVER use
    `yaml.load`, `yaml.unsafe_load`, `yaml.full_load`, or `yaml.Loader`/
    `FullLoader`/`UnsafeLoader` — pyyaml's full loader deserializes
    arbitrary Python types (e.g. `!!python/object/apply:os.system [...]`),
    so attacker-controlled config = RCE. `safe_load` restricts to the
    standard YAML tag set. SEE security review SEC-1 (D3 fix loop iter 1)
    and algorithms.md §A15 for rationale. DO NOT regress to `yaml.load` /
    `full_load` at impl time. This is a HARD constraint enforced at impl
    review by `sdk-security-devil`.

    [traces-to: TPRD-§11.4-load]
    """
    ...


