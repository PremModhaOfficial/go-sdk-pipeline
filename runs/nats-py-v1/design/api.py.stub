# --- 7.2 Circuit Breaker ---
class State(Enum):
    """str() returns 'closed'/'open'/'half-open'/'unknown'.
    [traces-to: TPRD-§9.2-State]
    """
    CLOSED = 0
    OPEN = 1
    HALF_OPEN = 2

# ErrCircuitOpen is defined in events.utils._errors (§2.4 above) per CONV-12 fix
# (D3 iter 3) — events.middleware._circuit_breaker IMPORTS it from there:
#
#   from motadata_py_sdk.events.utils import ErrCircuitOpen
#
# Sentinel ownership is in events.utils so `_NEVER_RETRY` can be populated at
# definition time (no import-order fragility, no global mutable state). Raising
# the sentinel from CB code paths is unchanged.

@dataclass
class CircuitBreakerConfig:
    """[traces-to: TPRD-§9.2-CircuitBreakerConfig]"""
    failure_threshold: int = 5
    success_threshold: int = 2
    timeout: float = 30.0
    on_state_change: Callable[[State, State], None] | None = None
    should_trip: Callable[[BaseException], bool] | None = None

class CircuitBreaker:
    """[traces-to: TPRD-§9.2-CircuitBreaker]
    [constraint: p50_allow_closed <= 0.5us | bench/bench_middleware_cb_allow_closed]

    State machine (locked transitions; on_state_change once per transition):
      CLOSED: pass; success → reset failures; should_trip(err) → failures++;
              if failures >= failure_threshold → OPEN, stamp last_failure_time.
      OPEN:   if elapsed > timeout → HALF_OPEN, allow this call;
              else raise ErrCircuitOpen.
      HALF_OPEN: every call allowed (HalfOpenMaxRequests NOT IMPL — mirror Go);
                 success++; >= success_threshold → CLOSED.
                 ANY failure → OPEN immediately.
      reset() force-transitions to CLOSED.
    """
    def __init__(self, cfg: CircuitBreakerConfig) -> None: ...
    async def allow(self) -> None: ...
    def on_success(self) -> None: ...
    def on_failure(self, err: BaseException) -> None: ...
    def state(self) -> State: ...
    def reset(self) -> None: ...

class MultiCircuitBreaker:
    """Per-subject CircuitBreaker dict (lazy create via lock-protected dict).
    [traces-to: TPRD-§9.2-MultiCircuitBreaker]
    [constraint: p50_get_cached <= 0.8us | bench/bench_middleware_multi_cb_get_cached]

    DIVERGENCE-UP optional: accepts key_fn(ctx, msg) -> str (default msg.subject)
    so callers can scope per-tenant: f'{tenant_id}:{msg.subject}' (scope.md §9.9).
    """
    def __init__(self, cfg: CircuitBreakerConfig,
                 key_fn: Callable[[Context, NatsMsg], str] | None = None) -> None: ...
    def get(self, subject: str) -> CircuitBreaker: ...

def circuit_breaker_middleware(cb: CircuitBreaker) -> PublishMiddleware:
    """Wrap publish handler with cb.allow() pre-check + on_success/on_failure post.
    [traces-to: TPRD-§9.2-circuit-breaker-middleware]
    """
    ...

# --- 7.3 Retry ---
@dataclass
class RetryConfig:
    """[traces-to: TPRD-§9.3-RetryConfig]"""
    max_attempts: int = 3
    initial_interval: float = 0.1
    max_interval: float = 5.0
    multiplier: float = 2.0
    jitter: float = 0.1
    should_retry: Callable[[BaseException], bool] | None = None  # default: is_retryable

def compute_backoff(attempt: int, cfg: RetryConfig) -> float:
    """Backoff formula PER §9.3 (must match exactly):
      1. backoff = initial_interval * (multiplier ** attempt)
      2. cap: if backoff > max_interval → backoff = max_interval
      3. jitter (only if jitter > 0):
           jitter_range = backoff * jitter
           jitter_val = jitter_range * (random()*2 - 1)  # uniform in [-r, +r)
           backoff += jitter_val
      4. floor (only if jitter enabled):
           if backoff < initial_interval → backoff = initial_interval
      5. return backoff
    Negative attempt normalized to 0.
    Jitter RNG: secrets.SystemRandom().random() (matches Go crypto/rand pattern).
    [traces-to: TPRD-§9.3-compute-backoff]
    [constraint: deterministic-when-jitter-zero bench/N/A]
    """
    ...

class RetryMiddleware:
    """[traces-to: TPRD-§9.3-RetryMiddleware]
    [constraint: p50_intercept_no_fail <= 3us | bench/bench_middleware_retry_no_fail]

    intercept_publish:
      Outer loop: for attempt in range(max_attempts + 1):
        - Check ctx.cancelled → return last_err or ctx.err.
        - Call next(ctx, msg). On success → return.
        - On error → save last_err.
        - If not should_retry(last_err) or attempt >= max_attempts → return last_err.
        - Otherwise wait_backoff(attempt); if ctx fires during wait →
          return last_err (NOT ctx.err — asymmetric with pre-attempt check).
    intercept_subscribe: pass-through (returns next as-is). Retry has no effect
    on subscribe path; rely on JetStream nak/term for redelivery.
    """
    def __init__(self, cfg: RetryConfig) -> None: ...
    def intercept_publish(self) -> PublishMiddleware: ...
    def intercept_subscribe(self) -> SubscribeMiddleware: ...

# --- 7.4 Rate limit ---

# ErrRateLimitExceeded is defined in events.utils._errors (§2.4 above) per
# CONV-12 fix (D3 iter 3) — events.middleware._rate_limit IMPORTS it from there:
#
#   from motadata_py_sdk.events.utils import ErrRateLimitExceeded
#
# Sentinel ownership is in events.utils so `_NEVER_RETRY` can be populated at
# definition time (no import-order fragility, no global mutable state). Raising
# the sentinel from rate-limit code paths is unchanged.
#
# The previous cross-module rebind pattern
# (`_utils._NEVER_RETRY = frozenset(_utils._NEVER_RETRY | {...})`) is REMOVED.

@dataclass
class RateLimiterConfig:
    """[traces-to: TPRD-§9.4-RateLimiterConfig]"""
    rate: float = 100.0
    burst: int = 50  # default config; int(rate) when constructor sees <= 0

class TokenBucketLimiter:
    """[traces-to: TPRD-§9.4-TokenBucketLimiter]
    [constraint: p50_allow_n <= 1.5us | bench/bench_middleware_token_bucket_allow]

    milliTokens internal (1 token = 1000 milliTokens) for sub-token precision
    using atomic int64 (Python: asyncio.Lock + int — atomic CAS not native;
    use Lock + plain int. Floor justification in perf-budget.md.)

    refill on every Allow*/Tokens read:
      elapsed = (now - last_update) / 1s
      new_tokens = elapsed * rate * 1000
      capped at burst*1000; on success last_update = now.
    """
    def __init__(self, cfg: RateLimiterConfig) -> None: ...
    async def allow_n(self, n: int = 1) -> bool: ...
    async def wait_n(self, n: int = 1) -> None:
        """Spin: if allow_n return; else
          deficit = needed - current
          wait_time = max(deficit/rate, 0.001)  # clamp >= 1ms
          await asyncio.wait_for(ctx_done, wait_time); retry.
        Propagates ctx err on cancel.
        [traces-to: TPRD-§9.4-wait-n]
        """
        ...
    def tokens(self) -> int: ...

class SlidingWindowLimiter:
    """[traces-to: TPRD-§9.4-SlidingWindowLimiter]
    [constraint: p50_allow <= 8us | bench/bench_middleware_sliding_window_allow]

    State: deque[int] (ns timestamps), asyncio.Lock-guarded.
    allow():
      lock; prune leading expired (ts <= now - window);
      if len >= limit → return False;
      else append now → return True.
    """
    def __init__(self, limit: int, window: float) -> None: ...
    def allow(self) -> bool: ...
    def count(self) -> int: ...

class PerSubjectRateLimiter:
    """[traces-to: TPRD-§9.4-PerSubjectRateLimiter]
    Lazy-creates TokenBucketLimiter per subject (independent caps).
    """
    def __init__(self, cfg: RateLimiterConfig) -> None: ...
    def get(self, subject: str) -> TokenBucketLimiter: ...

def rate_limit_middleware(rl: TokenBucketLimiter) -> PublishMiddleware:
    """Reject mode: immediate ErrRateLimitExceeded if !allow_n(1).
    [traces-to: TPRD-§9.4-rate-limit-middleware]
    """
    ...

def rate_limit_wait_middleware(rl: TokenBucketLimiter) -> PublishMiddleware:
