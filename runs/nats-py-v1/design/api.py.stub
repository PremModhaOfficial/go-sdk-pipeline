            )
        if self.ttl < 0:
            raise ValidationError(f"ObjectStoreConfig.ttl must be >= 0; got {self.ttl}")
        if self.max_bytes < 0:
            raise ValidationError(f"ObjectStoreConfig.max_bytes must be >= 0; got {self.max_bytes}")
        if self.replicas not in (1, 3, 5):
            raise ValidationError(
                f"ObjectStoreConfig.replicas must be 1, 3, or 5; got {self.replicas}"
