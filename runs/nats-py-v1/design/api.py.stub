            )

@dataclass
class ObjectMeta:
    """[traces-to: TPRD-§8.2-ObjectMeta]

    __post_init__ validation (CONV-5 fix, D3 iter 3): object name allows
    `.` `/` `_` `-` (path-like, per nats-py upstream); description length cap;
    chunk_size positive (zero would be a degenerate stream of zero-length
    chunks).
    """
    name: str
    description: str = ""
    headers: dict[str, str] = field(default_factory=dict)
    chunk_size: int = 128 * 1024  # 128 KiB default

    def __post_init__(self) -> None:
        if not self.name or not _OBJECT_NAME_REGEX.match(self.name):
            raise ValidationError(
                f"ObjectMeta.name must be non-empty and match {_OBJECT_NAME_REGEX.pattern!r}; got {self.name!r}"
            )
        if len(self.description) > _MAX_DESCRIPTION_LEN:
            raise ValidationError(
                f"ObjectMeta.description length must be <= {_MAX_DESCRIPTION_LEN}; got {len(self.description)}"
            )
        if self.chunk_size <= 0:
            raise ValidationError(f"ObjectMeta.chunk_size must be > 0; got {self.chunk_size}")

