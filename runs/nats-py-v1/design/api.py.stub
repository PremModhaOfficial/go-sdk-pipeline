# --- 7.5 Metrics ---
@dataclass(slots=True)
class Metrics:
    """In-process collected counters. [traces-to: TPRD-§9.5-Metrics]"""
    publish_count: int = 0
    publish_errors: int = 0
    publish_latency_ns: int = 0
    receive_count: int = 0
    receive_errors: int = 0
    receive_latency_ns: int = 0
    bytes_sent: int = 0
    bytes_received: int = 0

class MetricsCollector:
    """In-process collector with optional callback.
    [traces-to: TPRD-§9.5-MetricsCollector]

    intercept_publish: timestamp start; call next; atomic-increment publish_count,
      publish_latency, bytes_sent (len(msg.data)); on err publish_errors AND
      invoke the callback with metric attribute `error_kind=type(exc).__name__`
      (TPRD §15.34 FIX — bounded cardinality per the python-otel-instrumentation
      skill; only the sentinel class name is recorded, NEVER `str(exc)`); the
      bounded set is fixed by the 52-class hierarchy).
    intercept_subscribe: increment receive_count + bytes_received BEFORE next runs
      (asymmetric with publish — mirror Go). Process time + errors AFTER, with
      the same `error_kind` attribute on receive_errors per TPRD §15.34.
    """
    def __init__(self) -> None: ...
    def on_publish(self, fn: Callable[[Metrics], None]) -> None: ...
    def on_receive(self, fn: Callable[[Metrics], None]) -> None: ...
    def collect(self) -> Metrics: ...
    def reset(self) -> None: ...
    def intercept_publish(self) -> PublishMiddleware: ...
    def intercept_subscribe(self) -> SubscribeMiddleware: ...

class OTELMetricsMiddleware:
    """OTel metric emitter. Byte-exact metric names (mirror INV-6):
      events_publish_total            (counter,   subject)
      events_publish_errors_total     (counter,   subject, error_kind)
      events_publish_duration_ms      (histogram, subject, unit='ms')
      events_receive_total            (counter,   subject)
      events_receive_errors_total     (counter,   subject, error_kind)
      events_receive_duration_ms      (histogram, subject, unit='ms')
      events_bytes_sent_total         (counter,   subject)
      events_bytes_received_total     (counter,   subject)

    Resulting on-wire names prefix with <service_name>_ from registry namespace.
    Histogram unit is "ms" NOT "s" (README claim wrong; trust code per §9.5).
    Label dimensions:
      `subject` — present on every metric (caller-controlled but typically
                  drawn from a bounded subject taxonomy at the publisher).
      `error_kind` — present ONLY on the *_errors_total counters per TPRD §15.34
                     FIX. Bounded-cardinality sentinel: the value is
                     `type(exc).__name__` (one of the 52-class hierarchy
                     defined in events.utils + middleware), NEVER `str(exc)`.
                     The python-otel-instrumentation skill enforces this
                     bounded-cardinality discipline.

    [traces-to: TPRD-§9.5-OTELMetricsMiddleware §15.34]
    [constraint: wire-exact bench/N/A]
    [constraint: p50_intercept_publish <= 8us | bench/bench_middleware_otel_metrics_publish]
    """
    def __init__(self, meter: Any, namespace: str) -> None: ...
    def intercept_publish(self) -> PublishMiddleware: ...
    def intercept_subscribe(self) -> SubscribeMiddleware: ...

class PerSubjectMetrics:
