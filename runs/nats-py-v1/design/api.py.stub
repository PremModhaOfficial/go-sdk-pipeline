    [traces-to: TPRD-§7.3-create-tenant-consumer]
    """
    ...

async def get_consumer(js: Any, stream: str, name: str) -> Consumer: ...
async def delete_consumer(js: Any, stream: str, name: str) -> None: ...
async def list_consumers(js: Any, stream: str) -> list[str]: ...

def consumer_name(module: str, tenant_id: str) -> str:
    """Returns f'{module}-{tenant_id}'. [traces-to: TPRD-§7.3-consumer-name]"""
