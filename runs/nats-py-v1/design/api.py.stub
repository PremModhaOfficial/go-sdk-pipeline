# --- 8.2 motadata_py_sdk.otel.tracer ---
# Note: `from typing import Literal` imported in §9 (config) section; available
# at module scope for the dataclass annotations below since this file is
# concatenation-style stub (single namespace).
from typing import Literal as _Literal  # alias to avoid late-§9 redefinition

@dataclass(frozen=True, slots=True)
class TracerInitConfig:
    """[traces-to: TPRD-§10-TracerInitConfig §15.31 §SEMVER-4 §CONV-2]

    Frozen+slots per CONV-2 fix (H5-rev-3 D3 iter 2): immutable after
    construction. Mutation must use `dataclasses.replace(cfg, field=new)`.

    `otel_protocol` is `Literal["grpc", "http", "http/protobuf"]` per SEMVER-4
    fix; runtime validation in `__post_init__` per TPRD §15.31.
    """
    service: ServiceInfo
    enabled: bool = False
    otel_endpoint: str = "localhost:4317"
    otel_insecure: bool = True
    otel_protocol: _Literal["grpc", "http", "http/protobuf"] = "grpc"
    otel_debug: bool = False
    sampling_ratio: float = 1.0
    propagators: list[str] = field(default_factory=lambda: ["tracecontext", "baggage"])
    batch_timeout: float = 5.0
    max_export_batch: int = 512
    max_queue_size: int = 2048

    def __post_init__(self) -> None:
        """Runtime validation per TPRD §15.31 (FIX — pre-authorized; H5-rev-3
        D3 iter 2). Go's `Validate()` is a stub; Python tightens here.

        Raises:
            ValidationError: if any of:
              - service.name is blank
              - sampling_ratio not in [0.0, 1.0]
              - batch_timeout <= 0
              - max_export_batch <= 0
              - max_queue_size <= 0
              - max_export_batch > max_queue_size (capacity inversion)
              - otel_protocol not in {'grpc','http','http/protobuf'}  (also
                enforced statically by the Literal annotation; defense-in-depth)
              - otel_endpoint is blank when enabled=True
        """
        ...

async def init_tracer(cfg: TracerInitConfig) -> ShutdownCollector:
    """Initialize TracerProvider per cfg. Per §10.3 sampler:
      ratio <= 0 → ALWAYS_OFF
