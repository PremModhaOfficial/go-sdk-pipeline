# --- 5.4 Requester ---
class RequesterConfigError(ValueError):
    """Typed wrapper around the Go plain-string validation errors.
    [traces-to: TPRD-§7.4-RequesterConfigError]
    """

@dataclass
class RequesterConfig:
    """[traces-to: TPRD-§7.4-RequesterConfig]

    __post_init__ validation (CONV-5 fix, D3 iter 3): non-empty reply_stream
    + reply_subject_prefix + instance_id; positive request_timeout (capped at
    300s — anything longer is almost certainly a misconfig); positive
    inactive_threshold. Note: `nc` / `js` validity is NOT checked here (they
    are runtime handles); the existing `Requester.create` factory raises
    `RequesterConfigError` with the byte-exact 'requester: ...' message on
    those, preserving Go-byte-exact behavior. Field-level checks here run
    BEFORE the factory.
    """
    nc: Any
    js: Any
    reply_stream: str
    reply_subject_prefix: str
    instance_id: str
    max_payload: int = 0
    request_timeout: float = 30.0
    inactive_threshold: float = 300.0

    def __post_init__(self) -> None:
        if not self.reply_stream or not _STREAM_NAME_REGEX.match(self.reply_stream):
            raise ValidationError(
                f"RequesterConfig.reply_stream must be non-empty and match {_STREAM_NAME_REGEX.pattern!r}; got {self.reply_stream!r}"
            )
        if not self.reply_subject_prefix or not _SUBJECT_REGEX.match(self.reply_subject_prefix):
            raise ValidationError(
                f"RequesterConfig.reply_subject_prefix must be non-empty and match {_SUBJECT_REGEX.pattern!r}; got {self.reply_subject_prefix!r}"
            )
        if not self.instance_id or not _CONSUMER_NAME_REGEX.match(self.instance_id):
            raise ValidationError(
                f"RequesterConfig.instance_id must be non-empty and match {_CONSUMER_NAME_REGEX.pattern!r}; got {self.instance_id!r}"
            )
        if self.max_payload < 0:
            raise ValidationError(f"RequesterConfig.max_payload must be >= 0; got {self.max_payload}")
        if self.request_timeout <= 0:
            raise ValidationError(
                f"RequesterConfig.request_timeout must be > 0; got {self.request_timeout}"
            )
        if self.request_timeout > 300.0:
            raise ValidationError(
                f"RequesterConfig.request_timeout must be <= 300s; got {self.request_timeout}"
            )
        if self.inactive_threshold <= 0:
            raise ValidationError(
                f"RequesterConfig.inactive_threshold must be > 0; got {self.inactive_threshold}"
            )

@dataclass
class Response:
    """[traces-to: TPRD-§7.4-Response]"""
    status_code: int = 200
    message: str = ""
    data: JsMsg | None = None
    err: BaseException | None = None

    def ok(self) -> bool:
        """200 <= status_code < 300. [traces-to: TPRD-§7.4]"""
        ...

class Requester:
    """[traces-to: TPRD-§7.4-Requester]
    [constraint: p50 <= 2500us | bench/bench_jetstream_requester_request]
    """
    @classmethod
    async def create(cls, cfg: RequesterConfig) -> "Requester":
        """Per §7.4 create:
          1. Validate; on any required-field-empty raise RequesterConfigError
             with the byte-exact 'requester: ...' message.
          2. Span 'requester.init' attr stream, instance_id.
          3. filter_subject = f'{prefix}.{instance_id}.>'
             consumer_name = f'reply-{instance_id}'
          4. Build hard-coded ConsumerConfig (no Durable, ephemeral; ack=Explicit;
             max_ack_pending=1024; deliver=ALL; inactive_threshold=cfg.inactive_threshold).
          5. js.create_or_update_consumer(reply_stream, consumer_cfg).
          6. Construct internal JsPublisher; init pending: dict[str, asyncio.Future].
          7. Start consume; if consume() fails → DELETE the just-created consumer
             to avoid leak.
          8. INFO 'requester started' with stream, filter, instance_id.
        [traces-to: TPRD-§7.4-create]
        """
        ...

    async def request(self, subject: str, msg: NatsMsg) -> Response:
        """Per §7.4 request:
          1. request_id = f'{instance_id}-{ns_unix}-{seq}' (monotonic per-instance counter).
          2. reply_subject = f'{prefix}.{instance_id}.{request_id}'; alloc Future.
          3. Single lock acquire: closed → ErrClosed; else pending[request_id]=future.
          4. ctx no deadline → wrap with request_timeout (30s default).
          5. Span 'requester.request' attr messaging.destination=<subject>.
          6. defer del pending[request_id] under lock.
          7. msg.headers['X-Reply-To'] = reply_subject.
          8. self.publisher.publish(subject, msg); on err: 'requester: publish: <err>'.
          9. await Future or ctx:
             on reply: build_response(msg) (200 default; X-Status-Code int parse;
                       on parse fail silently keep 200; X-Message → message;
                       status >= 400 → err = Exception(f'status {sc}: {message or "request failed"}')).
             on timeout: return ErrRequestTimeout (NOT ctx err — important for isinstance).
        [traces-to: TPRD-§7.4-request]
        """
        ...

    async def close(self) -> None:
        """Idempotent. Flip closed under lock. Stop consume. Close internal publisher.
        DOES NOT delete ephemeral consumer (relies on server inactive_threshold=5m
        — mirror Go behavior; see scope.md).
        [traces-to: TPRD-§7.4-close]
        """
        ...


