"""
api.py.stub — Phase 1 Design API surface for `nats-py-v1`

PEP-484 type-annotated `class` + `def` skeletons with `...` bodies and full docstrings.
Single file, ~8 sections (one per package). Each section is a pyi-style stub of one
Python module. This file is the artifact every devil reviews at D2 and is the
contract `sdk-impl-lead` slices into 10 implementation passes (TPRD §14).

Markers used (G99 enforces `[traces-to:]` on every pipeline-authored symbol):
    [traces-to: TPRD-§<sec>-<id>]    where <id> = symbol name or check number
    [constraint: wire-exact bench/N/A]   for byte-exact wire invariants (no bench)
    [constraint: <metric> <op> <value> | bench/<BenchmarkName>]  for measurable

Authored: 2026-05-02 by sdk-design-lead.
Last edit: 2026-05-02 D3 fix loop iter 2 (H5-rev-3): TPRD §15 FIX items 28-34 applied
(TPRD-pre-authorized) + 8 carry-over WARNs (SEC-7, SEMVER-3, SEMVER-4, CONV-2..5, is_retryable
perf-budget row) closed. Q1/Q5/Q8 RESTORED (revocation overcorrection reversed per H5-rev-3).
"""
# pyright: ignore  (this is a stub, not real impl)
import re

# ============================================================================
# §1. motadata_py_sdk.codec  (TPRD §4.3)
# ============================================================================
"""Codec public surface.

[traces-to: TPRD-§4.3-Codec-Wire-Format]
[constraint: wire-exact bench/N/A]  -- byte-exact wire format; verified by
unit tests against fixtures, not bench.
"""
from __future__ import annotations
from enum import IntEnum
from typing import Any, Final

# --- 1.1 Encoder enum (header byte) ---
class Encoder(IntEnum):
    """Codec header byte. [traces-to: TPRD-§4.3-Header-Byte]

    CUSTOM = 0x00   custom binary, see §4.3.1
    MSGPACK = 0x01  msgpack with default options, see §4.3.2
    Other values raise ErrUnsupportedCodec on unpack.
    """
    CUSTOM = 0x00
    MSGPACK = 0x01

# --- 1.2 DataType tags (custom binary) ---
class DataType(IntEnum):
    """Custom-binary type tags. [traces-to: TPRD-§4.3.1-DataType-Tags]"""
    INVALID = 0
    BOOLEAN = 1
    INT8 = 2
    INT16 = 3
    INT24 = 4
    INT32 = 5
    INT40 = 6
    INT48 = 7
    INT56 = 8
    INT64 = 9
    FLOAT32 = 10
    FLOAT64 = 11
    STRING = 12
    ARRAY = 13
    BYTE_ARRAY = 14
    MAP = 15
    DATETIME = 16
    DATETIME_DURATION = 17

# --- 1.3 Sentinel exceptions (codec layer) ---
class CodecError(Exception):
    """Base class for codec sentinels. [traces-to: TPRD-§4.3.3]"""

class ErrUnpackFailed(CodecError):
    """[traces-to: TPRD-§4.3.3-ErrUnpackFailed]
    str() == "unpack failed: invalid or corrupted data"
    """

class ErrUnsupportedCodec(CodecError):
    """[traces-to: TPRD-§4.3.3-ErrUnsupportedCodec]
    str() == "unsupported codec type" or "unsupported codec type: 0x<NN>"
    """

class ErrUnsupportedDataType(CodecError):
    """str() == "unsupported data type" [traces-to: TPRD-§4.3.3]"""

class ErrValueOutOfRange(CodecError):
    """str() == "value out of supported range" [traces-to: TPRD-§4.3.3]"""

class ErrDataTooLarge(CodecError):
    """str() == "data too large for codec length fields" [traces-to: TPRD-§4.3.3]"""

# --- 1.4 Public functions ---
def pack_map(data: dict[str, Any], encoder: Encoder) -> bytes:
    """Encode a map per Encoder. Returns header byte + encoded payload.

    [traces-to: TPRD-§4.3.1-pack-map]
    [constraint: wire-exact bench/N/A]
    [constraint: p50 <= 30us | bench/bench_codec_pack_map_custom_10field]

    Width selection per §4.3.1 mirrors Go getDataTypeINT64.
    Raises ErrDataTooLarge if any string > 2^32 bytes or array > 65535 elements.
    Raises ErrValueOutOfRange if int > 2^63-1 or < -2^63.
    Raises ErrUnsupportedDataType if value type not in supported set.
    """
    ...

def pack_array(data: list[Any], encoder: Encoder) -> bytes:
    """Encode an array. Top-level length cap: 65535 per §4.3.4 quirk 1.

    [traces-to: TPRD-§4.3.1-pack-array]
    [constraint: wire-exact bench/N/A]
    Raises ErrDataTooLarge if len(data) > 65535.
    """
    ...

def unpack_map(buf: bytes) -> dict[str, Any]:
    """Decode bytes back to dict. Catches `(IndexError, UnicodeDecodeError,
    struct.error, ValueError)` and re-raises as `ErrUnpackFailed` (§4.3.3
    defer-recover analog). NOTE: `ValueError` was added at H5-rev-3 D3 iter 2
    (SEC-7 fix) — empirically `msgpack.unpackb` raises `ValueError` on cap
    violations (e.g., array32 declaring 1M entries against
    DEFAULT_MAX_ARRAY_LEN=64K), NOT `UnpackException`. We catch it at the
    codec boundary so callers see one sentinel class. See algorithms.md §A1.3
    + §A16.

    [traces-to: TPRD-§4.3.1-unpack-map]
    [constraint: wire-exact bench/N/A]
    [constraint: p50 <= 35us | bench/bench_codec_unpack_map_custom_10field]
    """
    ...

def unpack_array(buf: bytes) -> list[Any]:
    """Decode bytes back to list. Same recover semantics as unpack_map.

    [traces-to: TPRD-§4.3.1-unpack-array]
    [constraint: wire-exact bench/N/A]
    """
    ...

# --- 1.5 msgpack DoS-safety caps (SEC-2 D3 fix loop iter 1) ---
# All msgpack.unpackb() calls inside this module MUST go through
# msgpack_unpack_safe(). Calling msgpack.unpackb() directly is BANNED at
# impl-review time (sdk-security-devil enforces). RATIONALE: without these
# caps, attacker-controlled input claiming a 4 GiB string triggers a
# pre-allocation OOM before the buffer-length-mismatch error fires (msgpack
# eagerly allocates output buffers based on declared length fields). See
# algorithms.md §A16 and security review SEC-2 for full rationale.
DEFAULT_MAX_MSG_BYTES: Final[int] = 1024 * 1024 * 4   # 4 MiB hard cap; matches NATS default max_msg_size
DEFAULT_MAX_ARRAY_LEN: Final[int] = 1024 * 64
DEFAULT_MAX_MAP_LEN: Final[int] = 1024 * 64
DEFAULT_MAX_STR_LEN: Final[int] = 1024 * 256
DEFAULT_MAX_BIN_LEN: Final[int] = DEFAULT_MAX_MSG_BYTES

def msgpack_unpack_safe(data: bytes) -> Any:
    """DoS-safe wrapper around `msgpack.unpackb`. Use this everywhere we
    decode msgpack bytes; NEVER call `msgpack.unpackb(data)` directly inside
    this module. Caps enforce reasonable upper bounds on each msgpack
    container length to prevent pre-allocation OOM on malicious payloads.

    Args:
        data: raw msgpack-encoded bytes (no codec header byte).

    Returns:
        The decoded Python value (dict / list / scalar / datetime).

    Raises:
        ValueError: a length field exceeds one of the DEFAULT_MAX_* caps
            (msgpack-python raises `ValueError` for cap violations, NOT
            `UnpackException` — verified empirically at H5-rev-3 D3 iter 2
            SEC-7 review with crafted array32 declaring 1M entries).
        msgpack.exceptions.UnpackException: other malformed payloads
            (truncated buffer, unknown ext type, etc.).

    Both are caught at the codec facade (`unpack_map`/`unpack_array` per
    algorithms.md §A1.3) and re-raised as `ErrUnpackFailed`.

    [traces-to: TPRD-§4.3.2-msgpack-DoS-safety §SEC-7]
    """
    ...


# ============================================================================
# §2. motadata_py_sdk.events.utils  (TPRD §4.6)
# ============================================================================
"""All 33 sentinel exceptions, MultiError, is_retryable, is_temporary, constants.

[traces-to: TPRD-§4.6-Sentinel-Inventory]
[constraint: wire-exact bench/N/A]  -- 33 byte-exact strings; verified by
test_sentinel_strings parametrized over all 33 + 5 wrapper formats.
"""
from typing import Final

# --- 2.1 Constants ---
WildcardSingle: Final[str] = "*"            # [traces-to: TPRD-§4.4]
WildcardMulti: Final[str] = ">"
DefaultSeparator: Final[str] = "."
MaxSubjectLength: Final[int] = 256           # declared, not enforced (mirror Go)
MaxTenantIDLength: Final[int] = 128          # DECLARED AND ENFORCED in TenantKVStore/TenantObjectStore per TPRD §15.32 (restored at H5-rev-3 D3 iter 2)

# TenantID validation regex (FIX per TPRD §15.32 — pre-authorized at H5-rev-3 D3 iter 2)
# Pattern: starts alphanumeric, contains alphanumeric + underscore + hyphen only.
# Used by TenantKVStore.__init__ and TenantObjectStore.__init__ at runtime.
# Go SDK has NO enforcement; this is a Python-tightening per TPRD §15.32.
_TENANT_ID_REGEX: Final[re.Pattern[str]] = re.compile(r"^[A-Za-z0-9][A-Za-z0-9_-]*$")

# --- Dataclass __post_init__ validation regexes (CONV-5 fix, D3 iter 3) ---
# Centralized in events.utils so the 7 event-domain dataclass __post_init__
# validators (StreamConfig / ConsumerConfig / TenantConsumerConfig /
# RequesterConfig / KeyValueConfig / ObjectStoreConfig / ObjectMeta) can
# import a single source of truth. All raise `ValidationError` on miss.
# These are Python-internal hygiene; Go SDK has NO equivalent runtime checks.

# NATS stream name: alphanumeric + underscore + hyphen, no separator chars
# (no `.`, `>`, `*`, ` ` — those would collide with subject wildcards).
_STREAM_NAME_REGEX: Final[re.Pattern[str]] = re.compile(r"^[A-Za-z0-9_-]+$")

# NATS consumer name (durable name): same charset as stream name.
_CONSUMER_NAME_REGEX: Final[re.Pattern[str]] = re.compile(r"^[A-Za-z0-9_-]+$")

# JetStream subject pattern: dot-separated tokens; each token alphanumeric +
# underscore + hyphen; trailing `>` (multi-wildcard) or interior `*`
# (single-wildcard) permitted. Empty string rejected.
_SUBJECT_REGEX: Final[re.Pattern[str]] = re.compile(
    r"^([A-Za-z0-9_-]+|\*)(\.([A-Za-z0-9_-]+|\*))*(\.>)?$"
)

# KV / Object Store bucket name: same charset as stream/consumer name.
_BUCKET_NAME_REGEX: Final[re.Pattern[str]] = re.compile(r"^[A-Za-z0-9_-]+$")

# Object name: bucket charset + dot + slash (object names are path-like).
_OBJECT_NAME_REGEX: Final[re.Pattern[str]] = re.compile(r"^[A-Za-z0-9._/-]+$")

# Description / metadata cap (CONV-5): bound free-text fields so misuse
# can't push 1MB descriptions through the wire.
_MAX_DESCRIPTION_LEN: Final[int] = 1024

# Content-Type values (events/utils/const.go)
CONTENT_TYPE_JSON: Final[str] = "application/json"
CONTENT_TYPE_MSGPACK: Final[str] = "application/msgpack"
CONTENT_TYPE_OCTET_STREAM: Final[str] = "application/octet-stream"
CONTENT_TYPE_PROTOBUF: Final[str] = "application/protobuf"
CONTENT_TYPE_TEXT_PLAIN: Final[str] = "text/plain"

# --- 2.2 Sentinel exception base + 33 sentinels ---
class EventsError(Exception):
    """Root of the events sentinel hierarchy. [traces-to: TPRD-§4.6]
    Every sentinel below sets __str__ to a byte-exact string per §4.6.
    """

# 25 retryable sentinels (str() values byte-exact per §4.6 table)
class ErrNotConnected(EventsError): pass             # "not connected"
class ErrAlreadyConnected(EventsError): pass         # "already connected"
class ErrConnectionTimeout(EventsError): pass        # "connection timeout"  (temporary=yes)
class ErrReconnectFailed(EventsError): pass          # "reconnect failed"  (temporary=yes)
class ErrPublishFailed(EventsError): pass            # "publish failed"
class ErrPublishTimeout(EventsError): pass           # "publish timeout"  (temporary=yes)
class ErrNoAck(EventsError): pass                    # "no acknowledgment received" (temporary=yes)
class ErrStreamNotFound(EventsError): pass           # "stream not found"
class ErrInvalidMessage(EventsError): pass           # "invalid message"
class ErrMessageTooLarge(EventsError): pass          # "message too large"
class ErrRequestTimeout(EventsError): pass           # "request timeout"
class ErrNoReply(EventsError): pass                  # "no reply received"
class ErrSubscriptionClosed(EventsError): pass       # "subscription closed"
class ErrSubscriptionInvalid(EventsError): pass      # "subscription invalid"
class ErrMaxMessagesExceeded(EventsError): pass      # "max messages exceeded"
class ErrAuthFailed(EventsError): pass               # "authentication failed"
class ErrAuthExpired(EventsError): pass              # "authentication expired"
class ErrInvalidCredentials(EventsError): pass       # "invalid credentials"
class ErrTenantNotFound(EventsError): pass           # "tenant not found"
class ErrTenantExists(EventsError): pass             # "tenant already exists"
class ErrTenantDisconnected(EventsError): pass       # "tenant disconnected"
class ErrDeserializationFailed(EventsError): pass    # "deserialization failed"
class ErrJetStreamNotEnabled(EventsError): pass      # "jetstream not enabled"
class ErrInvalidArgument(EventsError): pass          # "invalid argument"
class ErrNoMessages(EventsError): pass               # "no messages available"
# ErrNoMessages: raised by Consumer.next() on empty fetch within deadline.
# Python-idiomatic translation of Go's plain-string `errors.New("no messages
# available")` return — Python lacks plain-string sentinels, so we expose a
# typed exception that participates in the EventsError hierarchy and is
# catchable via `except EventsError`. Default is_retryable behavior is True
# (the empty-queue case is transient; a Retry wrapper retrying after the
# next ack_wait window is the correct behavior). NOT in _NEVER_RETRY.

# 8 NON-retryable sentinels (returned False by is_retryable)
class ErrConnectionClosed(EventsError): pass         # "connection closed"
class ErrDuplicateMsg(EventsError): pass             # "duplicate message"
class ErrInvalidSubject(EventsError): pass           # "invalid subject"
class ErrPermissionDenied(EventsError): pass         # "permission denied"
class ErrInvalidConfig(EventsError): pass            # "invalid configuration"
class ErrMissingConfig(EventsError): pass            # "missing required configuration"
class ErrSerializationFailed(EventsError): pass      # "serialization failed"
class ErrShutdownInProgress(EventsError): pass       # "shutdown in progress"
class ErrClosed(EventsError): pass                   # "closed"

# --- 2.3 Wrapping types ---
class Error(EventsError):
    """{op, kind, err, details} wrapper. [traces-to: TPRD-§4.6-Error-Wrapper]
    str() format: '<kind>: <op>: <err>' or '<kind>: <err>' if no op.
    """
    op: str
    kind: str
    err: BaseException | None
    details: dict[str, Any]

class TenantError(EventsError):
    """{tenant_id, op, err}. str() == 'tenant <id>: <op>: <err>' or 'tenant <id>: <err>'.
    [traces-to: TPRD-§4.6-TenantError]
    """
    tenant_id: str
    op: str
    err: BaseException | None

class SerializationError(EventsError):
    """{operation, type, err}. str() == '<operation> <type>: <err>'.
    is_retryable returns False on instances. [traces-to: TPRD-§4.6-SerializationError]
    """

class ConfigError(EventsError):
    """{field, message}. str() == 'config error: <field>: <msg>'.
    is_retryable returns False on instances. [traces-to: TPRD-§4.6-ConfigError]
    """

class ValidationError(EventsError):
    """{field, message, value}. str() == 'validation error: <field>: <msg>'.
    [traces-to: TPRD-§4.6-ValidationError]
    """

class MultiError(EventsError):
    """N-error aggregate. Constructor takes Iterable[BaseException].
    [traces-to: TPRD-§4.6-MultiError]
    str() format:
      n==0 → 'no errors'
      n==1 → str(errs[0]) verbatim
      n>1  → '<n> errors occurred: <slice repr>'
    __cause__ / Unwrap() returns the FIRST collected error so
    `isinstance(multi, sentinel)` matches the most significant failure.
    """
    errors: list[BaseException]

# --- 2.4 Fail-fast wrapper sentinels (relocated from events.middleware per CONV-12 fix, D3 iter 3) ---
#
# Why these live in events.utils (NOT events.middleware):
#
# Original design (rev-1 through D3 iter 2) defined these in events.middleware
# and mutated `_NEVER_RETRY` from middleware/__init__.py at import time. That
# pattern was import-order-fragile (CONV-12, D3 iter 3): if a caller imported
# `events.utils.is_retryable` BEFORE any middleware module loaded, _NEVER_RETRY
# stayed empty and CB exceptions classified as retryable, defeating the
# breaker. It also violated CLAUDE.md rule 6 ("No global mutable state") via
# cross-module rebind.
#
# Resolution: move the two class definitions HERE (events.utils._errors), so
# `_NEVER_RETRY` can be populated at definition time from a single module.
# `events.middleware._circuit_breaker` and `_rate_limit` IMPORT these
# sentinels (not own them); raising them in middleware code is unchanged.
# The `_register_never_retry()` callback / module-init mutation pattern is
# REMOVED.
#
# Inheritance from `ErrPublishFailed` is preserved so
# `isinstance(e, ErrPublishFailed)` still matches (mirror Go error tree;
# verified by checks 116, 152). The `_NEVER_RETRY` exclusion in
# `is_retryable()` (below) keeps Retry middleware from retrying these
# despite the inheritance.

class ErrCircuitOpen(ErrPublishFailed):
    """Wraps ErrPublishFailed; kind='circuit_breaker', op='allow'.

    Inherits from ErrPublishFailed so `isinstance(e, ErrPublishFailed)` still
    matches (mirrors Go error tree; verified by check 116). However, this
    type is listed in `events.utils._NEVER_RETRY` so the Retry middleware
    does NOT retry it — composing Retry(CircuitBreaker(...)) preserves the
    fail-fast semantics of the open breaker. See the is_retryable() docstring
    for the exclusion-list rationale.

    Lives in events.utils (NOT events.middleware) so `_NEVER_RETRY` can be
    populated at definition time without import-order fragility (CONV-12 fix,
    D3 iter 3). `events.middleware._circuit_breaker` IMPORTS this sentinel.

    [traces-to: TPRD-§9.2-ErrCircuitOpen]
    """

class ErrRateLimitExceeded(ErrPublishFailed):
    """Wraps ErrPublishFailed; kind='rate_limiter', op='allow'.

    Inherits from ErrPublishFailed so `isinstance(e, ErrPublishFailed)` still
    matches (mirrors Go error tree; verified by check 152). However, this
    type is listed in `events.utils._NEVER_RETRY` so the Retry middleware
    does NOT retry it — composing Retry(RateLimit(...)) preserves the
    fail-fast semantics of an exhausted limiter. See the is_retryable()
    docstring for the exclusion-list rationale.

    Lives in events.utils (NOT events.middleware) so `_NEVER_RETRY` can be
    populated at definition time without import-order fragility (CONV-12 fix,
    D3 iter 3). `events.middleware._rate_limit` IMPORTS this sentinel.

    [traces-to: TPRD-§9.4-ErrRateLimitExceeded]
    """

# --- 2.5 Classifier helpers ---

# _NEVER_RETRY: types whose inheritance chain reaches retryable bases (e.g.
# ErrPublishFailed) but whose semantics are explicitly fail-fast. Checked
# BEFORE the inheritance walk so isinstance(e, ErrPublishFailed) does NOT
# auto-promote them to retryable. Defeats the composition footgun where
# `Retry(CircuitBreaker(...))` would retry through an OPEN breaker.
#
# Populated AT DEFINITION TIME (CONV-12 fix, D3 iter 3): both fail-fast
# wrapper sentinels (ErrCircuitOpen, ErrRateLimitExceeded) are defined
# above in this same module, so we can inline them into the frozenset.
# The previous design forward-declared this as `frozenset()` and mutated
# it from middleware/__init__.py at import time — that pattern was
# import-order-fragile and violated CLAUDE.md rule 6 (no global mutable
# state). The cross-module rebind is REMOVED.
_NEVER_RETRY: Final[frozenset[type[BaseException]]] = frozenset({
    ErrCircuitOpen,
    ErrRateLimitExceeded,
})

def is_retryable(err: BaseException) -> bool:
    """Whether this error should be retried by the Retry middleware.

    Returns False for:
      1. Any type listed in `_NEVER_RETRY` (currently ErrCircuitOpen,
         ErrRateLimitExceeded). Checked FIRST — these inherit from
         ErrPublishFailed but their semantics are fail-fast; retrying
         defeats the breaker / limiter.
      2. Any of the 8 non-retryable sentinels (ErrConnectionClosed,
         ErrDuplicateMsg, ErrInvalidSubject, ErrPermissionDenied,
         ErrInvalidConfig, ErrMissingConfig, ErrSerializationFailed,
         ErrShutdownInProgress, ErrClosed).
      3. Any SerializationError / ConfigError instance.

    Returns True otherwise (for retryable EventsError subtypes).

    NOTE on inheritance: `ErrCircuitOpen(ErrPublishFailed)` and
    `ErrRateLimitExceeded(ErrPublishFailed)` MUST keep that inheritance
    so callers using `isinstance(e, ErrPublishFailed)` still match Go's
    error-tree behavior (verified by checks 116, 152). The behavioral
    fix is the explicit `_NEVER_RETRY` exclusion in this function — the
    type hierarchy is unchanged.

    NOTE on ownership (CONV-12 fix, D3 iter 3): both fail-fast wrappers
    are defined in events.utils._errors (this module) so `_NEVER_RETRY`
    is populated at definition time. Earlier designs declared them in
    events.middleware and mutated `_NEVER_RETRY` cross-module — that
    pattern was import-order-fragile (caller importing
    `events.utils.is_retryable` first would see an empty set). The
    middleware modules now IMPORT these sentinels from events.utils
    rather than owning them.

    [traces-to: TPRD-§4.6-is-retryable]
    [constraint: p50 <= 500ns | bench/bench_is_retryable_typical]
    [constraint: allocs_per_op == 0 | bench/bench_is_retryable_typical]
    """
    ...

def is_temporary(err: BaseException) -> bool:
    """Returns True only for: ErrConnectionTimeout, ErrReconnectFailed,
    ErrPublishTimeout, ErrNoAck. False otherwise.
    [traces-to: TPRD-§4.6-is-temporary]
    """
    ...


# ============================================================================
# §3. motadata_py_sdk.events.core  (TPRD §5 + §4.1, §4.2)
# ============================================================================
"""TraceContext, Metadata, 15 byte-exact header constants, ExtractHeaders,
InjectContext, contextvars helpers. Pure-contract; no I/O.

[traces-to: TPRD-§5-Module-events-core]
[constraint: wire-exact bench/N/A]  -- 15 header constants byte-exact;
verified by test_header_constants parametrized over all 15.
"""
from contextvars import ContextVar
from dataclasses import dataclass, field
from datetime import datetime
from typing import Awaitable, Callable, Final, Protocol

# --- 3.1 The 15 byte-exact header constants ---
HEADER_CONTENT_TYPE: Final[str] = "Content-Type"
HEADER_MESSAGE_ID: Final[str] = "Nats-Msg-Id"
HEADER_CORRELATION_ID: Final[str] = "Correlation-ID"
HEADER_TENANT_ID: Final[str] = "X-Tenant-ID"
HEADER_TRACE_ID: Final[str] = "X-Trace-ID"
HEADER_SPAN_ID: Final[str] = "X-Span-ID"
HEADER_TRACEPARENT: Final[str] = "traceparent"
HEADER_TRACESTATE: Final[str] = "tracestate"
HEADER_B3_TRACE_ID: Final[str] = "X-B3-TraceId"
HEADER_B3_SPAN_ID: Final[str] = "X-B3-SpanId"
HEADER_B3_SAMPLED: Final[str] = "X-B3-Sampled"
HEADER_B3_PARENT_SPAN_ID: Final[str] = "X-B3-ParentSpanId"  # declared, never written or read
HEADER_REPLY_TO: Final[str] = "X-Reply-To"
HEADER_STATUS_CODE: Final[str] = "X-Status-Code"
HEADER_MESSAGE: Final[str] = "X-Message"

# --- 3.2 Public types ---
@dataclass(frozen=True, slots=True)
class TraceContext:
    """W3C-shaped trace identifiers. [traces-to: TPRD-§5.1-TraceContext]
    Note: span_id is nominally 16-hex but Go SDK emits 32-hex (Known issue).
    Mirror Go: store as-received; do not reformat.
    """
    trace_id: str = ""
    span_id: str = ""
    parent_id: str = ""    # not populated by InjectContext
    sampled: bool = False
    state: str = ""

@dataclass(slots=True)
class Metadata:
    """In-process aggregate. NOT a wire schema.
    [traces-to: TPRD-§5.1-Metadata]
    GAP MIRRORED: timestamp + custom NOT auto-serialized to headers.
    """
    tenant_id: str = ""
    correlation_id: str = ""
    message_id: str = ""
    timestamp: datetime | None = None
    custom: dict[str, str] = field(default_factory=dict)

# --- 3.3 Protocols (interfaces) ---
class NatsMsg(Protocol):
    """Structural contract for a NATS message. Concrete impls come from
    nats-py (`nats.aio.msg.Msg`). We type-only-import to avoid leak into runtime.
    [traces-to: TPRD-§5.2]
    """
    subject: str
    data: bytes
    headers: dict[str, str] | None
    reply: str

MessageHandler = Callable[["Context", NatsMsg], Awaitable[None]]
"""Async handler. Raise an exception to signal failure (Go returns `error`)."""

class Context(Protocol):
    """Opaque async context. In Python this is just the implicit asyncio context;
    we model it as a Protocol to keep ExtractHeaders/InjectContext signatures
    explicit. Concrete = `dict[str, Any]` or `contextvars.copy_context()` snapshot.
    [traces-to: TPRD-§5.2]
    """
    ...

class Publisher(Protocol):
    """[traces-to: TPRD-§5.2-Publisher-Protocol]"""
    async def publish(self, subject: str, msg: NatsMsg) -> None: ...
    async def request(self, subject: str, msg: NatsMsg) -> NatsMsg: ...
    async def close(self) -> None: ...

class Subscriber(Protocol):
    """[traces-to: TPRD-§5.2-Subscriber-Protocol]"""
    async def subscribe(self, subject: str, handler: MessageHandler) -> "Subscription": ...
    async def queue_subscribe(self, subject: str, queue: str, handler: MessageHandler) -> "Subscription": ...
    async def close(self) -> None: ...

class Subscription(Protocol):
    """[traces-to: TPRD-§5.2-Subscription-Protocol]"""
    def subject(self) -> str: ...
    async def unsubscribe(self) -> None: ...   # immediate teardown, drops pending
    async def drain(self) -> None: ...         # graceful: stop new deliveries, finish in-flight
    def is_valid(self) -> bool: ...

# --- 3.4 contextvars helpers ---
# ONE ContextVar per slot; do not collapse (Go uses unexported contextKey int per slot).
_tenant_id_var: ContextVar[str | None] = ContextVar("tenant_id", default=None)
_trace_context_var: ContextVar[TraceContext | None] = ContextVar("trace_context", default=None)
_message_id_var: ContextVar[str | None] = ContextVar("message_id", default=None)
_correlation_id_var: ContextVar[str | None] = ContextVar("correlation_id", default=None)
_reply_to_var: ContextVar[str | None] = ContextVar("reply_to", default=None)
_metadata_var: ContextVar[Metadata | None] = ContextVar("metadata", default=None)

def set_tenant_id(tenant_id: str) -> object:
    """Set tenant_id in current contextvars context. Returns Token for reset.
    [traces-to: TPRD-§5.1-WithTenantID]"""
    ...

def get_tenant_id() -> str | None:
    """[traces-to: TPRD-§5.1-TenantIDFromContext]"""
    ...

# Same set/get pair for: trace_context, message_id, correlation_id, reply_to, metadata.
def set_trace_context(tc: TraceContext) -> object: ...
def get_trace_context() -> TraceContext | None: ...
def set_message_id(message_id: str) -> object: ...
def get_message_id() -> str | None: ...
def set_correlation_id(correlation_id: str) -> object: ...
def get_correlation_id() -> str | None: ...
def set_reply_to(reply_to: str) -> object: ...
def get_reply_to() -> str | None: ...
def set_metadata(meta: Metadata) -> object: ...
def get_metadata() -> Metadata | None: ...

def extract_otel_trace_context() -> TraceContext | None:
    """Read active OTel span via opentelemetry.trace.get_current_span().
    Returns TraceContext{trace_id, span_id, sampled=True} when both IDs non-zero;
    None when no active span. [traces-to: TPRD-§5.1-ExtractOTELTraceContext]
    """
    ...

# --- 3.5 ExtractHeaders / InjectContext (byte-exact per §4.2) ---
def extract_headers(headers: dict[str, str] | None) -> dict[str, str]:
    """Publisher-side writer. Order of operations PER §4.2 (must reproduce):

      1. headers = headers or {}
      2. tenant_id from ctx → "X-Tenant-ID"
      3. extract_trace_headers (OTel-active path → all 5 trace headers + traceparent;
         else manual TraceContext path → same 5 with sampled-conditional X-B3-Sampled
         and traceparent flag "01"/"00"; else no-op)
      4. correlation_id → "Correlation-ID"
      5. message_id → "Nats-Msg-Id"
      6. reply_to → "X-Reply-To"

    [traces-to: TPRD-§4.2-extract-headers]
    [constraint: wire-exact bench/N/A]
    [constraint: p50 <= 25us | bench/bench_extract_headers_otel_active]
    [constraint: allocs_per_op <= 8 | bench/bench_extract_headers_otel_active]
    """
    ...

def inject_context(headers: dict[str, str] | None) -> None:
    """Subscriber-side reader. Order PER §4.2 (must reproduce):

      1. If headers is None → return without changes.
      2. X-Tenant-ID → set_tenant_id
      3. Build TraceContext: trace_id = headers["X-Trace-ID"] or headers["X-B3-TraceId"];
         span_id = headers["X-Span-ID"] or headers["X-B3-SpanId"];
         sampled = headers["X-B3-Sampled"] in ("1", "true");
         state = headers["tracestate"]
         If trace_id != "" or span_id != "" → set_trace_context.
      4. Correlation-ID → set_correlation_id
      5. Nats-Msg-Id → set_message_id
      6. X-Reply-To → set_reply_to

    Critical asymmetry: traceparent is NOT parsed (mirror Go bug; H5-rev-2 confirms
    MIRROR — TracingMiddleware does NOT call propagator.extract on subscribe).

    [traces-to: TPRD-§4.2-inject-context]
    [constraint: wire-exact bench/N/A]
    """
    ...


# ============================================================================
# §4. motadata_py_sdk.events.corenats  (TPRD §6)
# ============================================================================
"""Concrete Publisher / BatchPublisher / Subscriber over plain NATS.
[traces-to: TPRD-§6-Module-events-corenats]
"""
from typing import Any, Callable, Mapping
import asyncio
# nats import deferred to runtime; type-only here.

# --- 4.1 Constants (mirror Go file-scoped) ---
DEFAULT_REQUEST_TIMEOUT: Final[float] = 30.0       # seconds
DEFAULT_FLUSH_TIMEOUT: Final[float] = 5.0          # seconds
DEFAULT_MAX_CONCURRENT_FLUSH: Final[int] = 64
ATTR_MESSAGING_DESTINATION: Final[str] = "messaging.destination"

# --- 4.2 Publisher ---
PublishHandler = Callable[[Context, NatsMsg], Awaitable[None]]
PublishMiddleware = Callable[[PublishHandler], PublishHandler]

class Publisher:
    """Plain-NATS publisher.

    [traces-to: TPRD-§6.2-Publisher]
    [constraint: p50 <= 350us | bench/bench_corenats_publisher_publish_1kb]
    [constraint: allocs_per_op <= 12 | bench/bench_corenats_publisher_publish_1kb]
    """
    def __init__(self, nc: Any, max_payload: int) -> None:
        """`nc` is a `nats.aio.client.Client` (caller-owned). max_payload stored
        but NOT enforced in publish per Go behavior; pre-validation deferred
        (see scope.md). [traces-to: TPRD-§6.2]
        """
        ...

    def use_middleware(self, mw: PublishMiddleware) -> None:
        """Append; new mw becomes innermost of existing chain.
        Compose existing(mw(next)). [traces-to: TPRD-§6.2-use-middleware]
        """
        ...

    async def publish(self, subject: str, msg: NatsMsg) -> None:
        """Per §6.2: closed check → snapshot mw → wrap → invoke.
        Inner: span 'nats.publish' attrs (TPRD §15.28 messaging.* applied):
            messaging.system='nats'
            messaging.destination=<subject>
            messaging.operation='publish'
        nc is None → ErrNotConnected; mutate msg.subject=subject; nc.publish_msg(msg);
        on err: span.set_error, log, return; on ok: span.set_ok.
        [traces-to: TPRD-§6.2-publish §15.28]
        """
        ...

    async def request(self, subject: str, msg: NatsMsg) -> NatsMsg:
        """Per §6.2 request semantics. Translates nats.errors.TimeoutError →
        ErrRequestTimeout; nats.errors.NoRespondersError → ErrNoReply.
        Middleware runs as pre-send hook only.
        [traces-to: TPRD-§6.2-request]
        """
        ...

    async def request_with_timeout(self, subject: str, msg: NatsMsg, timeout: float) -> NatsMsg:
        """Thin wrapper with asyncio.wait_for. [traces-to: TPRD-§6.2-request-with-timeout]"""
        ...

    async def close(self) -> None:
        """Idempotent. Acquires write lock; flips closed; nc.flush(timeout)
        where timeout = DEFAULT_FLUSH_TIMEOUT (5s). [traces-to: TPRD-§6.2-close]
        """
        ...

# --- 4.3 BatchPublisher ---
class BatchPublisher:
    """Buffered publisher.

    [traces-to: TPRD-§6.3-BatchPublisher]
    [constraint: p50_add <= 8us | bench/bench_corenats_batch_publisher_add]
    [constraint: p50_flush_concurrent <= 12000us | bench/bench_corenats_batch_publisher_flush_concurrent_100]
    """
    def __init__(
        self,
        publisher: Publisher,
        *,
        max_batch_size: int = 0,           # 0 = no size trigger
        flush_interval: float = 0.0,       # 0 = no auto-flush task
        concurrent_flush: bool = False,
        max_flush_workers: int = 64,       # ignored if <= 0; default stays 64
        on_flush_error: Callable[[BaseException], None] | None = None,
    ) -> None:
        """[traces-to: TPRD-§6.3]
        Pre-allocates buffer (Go: cap 100). Spawns auto-flush task only if
        flush_interval > 0.
        """
        ...

    async def add(self, subject: str, msg: NatsMsg) -> None:
        """Lock; append; if max_batch_size > 0 and len >= max_batch_size →
        synchronous flush() with FRESH BACKGROUND CONTEXT (mirrors Go bug;
        see scope.md Q12). Caller's ctx is dropped on size-trigger flush.
        [traces-to: TPRD-§6.3-add]
        """
        ...

    async def add_multiple(self, messages: Mapping[str, NatsMsg]) -> None:
        """Same as add but batched. Iteration order = dict insertion order
        (Python). Go uses random map order; document divergence.
        [traces-to: TPRD-§6.3-add-multiple]
        """
        ...

    async def flush(self) -> None:
        """Lock; if empty → return None. Atomically swap buffer (replace with
        new list, preserve cap). Then flush_concurrent or flush_sequential.
        Errors aggregated: 0 → None; 1 → that error; >1 → MultiError.
        Concurrent: n_workers = min(max_flush_workers, len(batch)) via
        asyncio.gather + bounded asyncio.Semaphore.
        [traces-to: TPRD-§6.3-flush]
        """
        ...

    def count(self) -> int:
        """Current pending count. [traces-to: TPRD-§6.3-count]"""
        ...

    async def close(self) -> None:
        """Cancel auto-flush task; await; final flush(). Idempotent.
        [traces-to: TPRD-§6.3-close]
        """
        ...

# --- 4.4 Subscriber ---
SubscribeHandler = Callable[[Context, NatsMsg], Awaitable[None]]
SubscribeMiddleware = Callable[[SubscribeHandler], SubscribeHandler]

class _Subscription:
    """Internal Subscription impl wrapping nats-py's Subscription.
    [traces-to: TPRD-§6.4-Subscription-impl]
    """
    def subject(self) -> str: ...
    async def unsubscribe(self) -> None: ...
    async def drain(self) -> None: ...
    def is_valid(self) -> bool: ...

class Subscriber:
    """Plain-NATS subscriber (callback-based).

    [traces-to: TPRD-§6.4-Subscriber]
    [constraint: p50_callback_dispatch <= 25us | bench/bench_corenats_subscriber_dispatch]
    """
    def __init__(
        self,
        nc: Any,
        *,
        on_error: Callable[[BaseException], Awaitable[None]] | None = None,
    ) -> None:
        """`nc` is caller-owned.

        Args:
            nc: caller-owned `nats.aio.client.Client`.
            on_error: optional async callback invoked from the close/dispatch
                paths whenever a non-fatal error is caught (e.g., a
                subscription drain failure during `close()`). Default `None`
                preserves Go SDK behavior (silent log + return; errors
                NEVER propagate to caller). Set this hook to opt in to
                error surfacing without changing the public method signatures.

                The hook MUST NOT raise — if it does, the exception is
                swallowed with a single `log.exception` (avoids recursion).

        [traces-to: TPRD-§6.4]
        """
        ...

    def use_middleware(self, mw: SubscribeMiddleware) -> None:
        """Same chain semantics as Publisher.use_middleware.
        [traces-to: TPRD-§6.4-use-middleware]
        """
        ...

    def set_error_handler(
        self,
        cb: Callable[[BaseException], Awaitable[None]] | None,
    ) -> None:
        """Replace or clear the on_error hook post-construction. Pass None to
        revert to Go-default silent behavior. Thread-safe (single asyncio task).
        [traces-to: TPRD-§6.4-set-error-handler]
        """
        ...

    async def subscribe(self, subject: str, handler: SubscribeHandler) -> Subscription:
        """Per §6.4 subscribe semantics:
        - Span 'nats.subscribe' attrs (TPRD §15.28 messaging.* applied):
            messaging.system='nats'
            messaging.destination=<subject>
            messaging.operation='subscribe'
        - check_ready (closed → ErrConnectionClosed; nc disconnected → ErrNotConnected);
        - per-sub cancel token; wrap handler with current chain (snapshot under lock);
        - Build NATS callback: if cancel fired → drop; else span 'nats.receive',
          attrs={'messaging.system': 'nats', 'messaging.destination': <subject>,
                 'messaging.operation': 'receive'} (TPRD §15.28),
          call wrapped handler, set status, end.
        - Handler errors NOT propagated to NATS (no NAK in core NATS).
        - nc.subscribe; store in slice + index map keyed by underlying sub ptr.
        - INFO log 'NATS subscription created' with subject, queue.
        [traces-to: TPRD-§6.4-subscribe §15.28]
        """
        ...

    async def queue_subscribe(self, subject: str, queue: str, handler: SubscribeHandler) -> Subscription:
        """Same as subscribe; span name 'nats.queue_subscribe'; attr +messaging.queue.
        [traces-to: TPRD-§6.4-queue-subscribe]
        """
        ...

    async def unsubscribe(self, sub: Subscription) -> None:
        """Named 'unsubscribe' but ACTUALLY CALLS sub.drain() (mirror Go bug;
        see scope.md Q11). Type-check; if not internal → silent no-op.
        Lock; remove from index + slice; unlock; sub.drain().
        [traces-to: TPRD-§6.4-unsubscribe]
        """
        ...

    async def close(self) -> None:
        """Span 'nats.subscriber.close'. Write-lock; closed=True; for each sub:
        cancel token, sub.drain(); collect errs; on any drain err: WARN
        'errors draining subscriptions during close' with error_count.
        ERRORS NOT RETURNED (mirrors Go behavior). If `on_error` hook was
        registered at construction, each caught drain error is also passed
        to `await on_error(exc)` BEFORE the WARN log; hook errors are
        swallowed via log.exception to avoid close-time recursion.
        INFO 'NATS subscriber closed' with subscriptions_closed.
        Returns None unconditionally. [traces-to: TPRD-§6.4-close]
        """
        ...


# ============================================================================
# §5. motadata_py_sdk.events.jetstream  (TPRD §7)
# ============================================================================
"""Stream mgmt, sync + async Publisher, pull Consumer, sync-over-async Requester.
[traces-to: TPRD-§7-Module-events-jetstream]
"""
from enum import Enum

# --- 5.1 StreamConfig + Stream ---
class Retention(Enum):
    LIMITS = "limits"
    INTEREST = "interest"
    WORK_QUEUE = "work_queue"

class StorageType(Enum):
    FILE = "file"
    MEMORY = "memory"

@dataclass
class StreamConfig:
    """[traces-to: TPRD-§7.1-StreamConfig]
    [constraint: wire-exact bench/N/A]  -- 3 hard-coded fields below.

    __post_init__ validation (CONV-5 fix, D3 iter 3): runs at construction time;
    raises `ValidationError` on bad input. Go SDK has no equivalent runtime check
    (it would surface the error at JetStream API call time); Python tightens
    here per `python-class-design` skill rule. See `_STREAM_NAME_REGEX`,
    `_SUBJECT_REGEX`, `_MAX_DESCRIPTION_LEN` in events.utils.
    """
    name: str
    subjects: list[str]
    retention: Retention = Retention.LIMITS
    max_msgs: int = 0
    max_bytes: int = 0
    max_age: float = 0.0
    max_msg_size: int = 0
    replicas: int = 1
    storage: StorageType = StorageType.FILE
    description: str = ""
    max_msgs_per_subject: int = 0
    discard_new_per_subject: bool = False
    allow_rollup: bool = False
    deny_delete: bool = False
    deny_purge: bool = False
    # Hard-coded (mirror INV-8):
    # discard = DiscardOld, duplicates = 120.0s, allow_direct = True

    def __post_init__(self) -> None:
        if not self.name or not _STREAM_NAME_REGEX.match(self.name):
            raise ValidationError(
                f"StreamConfig.name must be non-empty and match {_STREAM_NAME_REGEX.pattern!r}; got {self.name!r}"
            )
        if not self.subjects:
            raise ValidationError("StreamConfig.subjects must contain at least one subject")
        for s in self.subjects:
            if not _SUBJECT_REGEX.match(s):
                raise ValidationError(
                    f"StreamConfig.subjects entry {s!r} must match {_SUBJECT_REGEX.pattern!r}"
                )
        if self.max_msgs < 0:
            raise ValidationError(f"StreamConfig.max_msgs must be >= 0; got {self.max_msgs}")
        if self.max_bytes < 0:
            raise ValidationError(f"StreamConfig.max_bytes must be >= 0; got {self.max_bytes}")
        if self.max_age < 0:
            raise ValidationError(f"StreamConfig.max_age must be >= 0; got {self.max_age}")
        if self.max_msg_size < 0:
            raise ValidationError(f"StreamConfig.max_msg_size must be >= 0; got {self.max_msg_size}")
        if self.replicas not in (1, 3, 5):
            raise ValidationError(f"StreamConfig.replicas must be 1, 3, or 5; got {self.replicas}")
        if len(self.description) > _MAX_DESCRIPTION_LEN:
            raise ValidationError(
                f"StreamConfig.description length must be <= {_MAX_DESCRIPTION_LEN}; got {len(self.description)}"
            )

class Stream:
    """[traces-to: TPRD-§7.1-Stream]
    [constraint: p50_create <= 8000us | bench/bench_jetstream_stream_create]
    """
    def name(self) -> str: ...
    async def info(self) -> Any: ...                                      # nats.js.api.StreamInfo
    async def purge(self) -> None: ...                                    # span 'stream.purge'
    async def delete(self) -> None: ...                                   # span 'stream.delete'
    async def subjects(self) -> list[str]: ...
    async def add_subjects(self, *subjects: str) -> None: ...             # idempotent (dedups)
    async def remove_subjects(self, *subjects: str) -> None: ...          # rejects removal of all
    async def set_subjects(self, subjects: list[str]) -> None: ...        # rejects empty

# --- Factory functions (mirror Go free funcs) ---
async def create_stream(js: Any, cfg: StreamConfig) -> Stream:
    """Span 'stream.create' attr stream=<name>. INFO 'stream created' with stream.
    Validation: empty name → ErrInvalidArgument details {'reason': 'name is required'};
    empty subjects → details {'reason': 'at least one subject is required'};
    js is None → ErrJetStreamNotEnabled (Python uses sentinel; Go used string err).
    Fails on existing stream (does NOT create-or-update).
    [traces-to: TPRD-§7.1-create-stream]
    """
    ...

async def create_or_update_stream(js: Any, cfg: StreamConfig) -> Stream:
    """Span 'stream.create_or_update'. Does NOT log on success (mirror Go gap).
    [traces-to: TPRD-§7.1-create-or-update-stream]
    """
    ...

async def get_stream(js: Any, name: str) -> Stream: ...
async def delete_stream(js: Any, name: str) -> None:
    """No span, no log (mirror Go asymmetry; Stream.delete does emit).
    [traces-to: TPRD-§7.1-delete-stream]
    """
    ...
async def list_streams(js: Any) -> list[str]: ...

# --- 5.2 JsPublisher ---
@dataclass(frozen=True, slots=True)
class PubAck:
    """[traces-to: TPRD-§7.2-PubAck]"""
    stream: str
    sequence: int
    domain: str

class JsPublisher:
    """JetStream publisher.

    [traces-to: TPRD-§7.2-Publisher]
    [constraint: p50 <= 1500us | bench/bench_jetstream_publisher_publish_1kb]
    [constraint: p50_async <= 30us | bench/bench_jetstream_publisher_publish_async_1kb]
    """
    def __init__(self, nc: Any, js: Any, max_payload: int) -> None: ...

    def use_middleware(self, mw: PublishMiddleware) -> None: ...

    async def publish(self, subject: str, msg: NatsMsg) -> PubAck:
        """Closed check → ErrConnectionClosed. Wrap ctx with 10s if no deadline.
        Inner: subject=='' → ErrInvalidSubject; msg is None → ErrInvalidMessage;
        oversized → ErrMessageTooLarge with format
          '<sentinel>: <N> bytes exceeds <limit> limit';
        js is None → ErrJetStreamNotEnabled.
        Set msg.subject; if Nats-Msg-Id header set → engages dedup.
        Span 'jetstream.publish' attrs (TPRD §15.28 messaging.* applied):
            messaging.system='nats'
            messaging.destination=<subject>
            messaging.operation='publish'
        Returns PubAck{stream, sequence, domain}.
        [traces-to: TPRD-§7.2-publish §15.28]
        """
        ...

    def publish_async(self, subject: str, msg: NatsMsg) -> "asyncio.Future[PubAck]":
        """Allocate Future; closed → set ErrConnectionClosed; spawn task to
        run js.publish_msg + middleware. NO PRE-VALIDATION (mirror Go gap;
        see scope.md). NO CALLER-SIDE CONCURRENCY LIMIT (unbounded tasks).
        Inner span 'jetstream.publish' attrs (TPRD §15.28):
            messaging.system='nats'
            messaging.destination=<subject>
            messaging.operation='publish'
        ERROR log 'async JetStream publish failed' on err with subject, err.
        [traces-to: TPRD-§7.2-publish-async §15.28]
        """
        ...

    async def close(self) -> None:
        """Idempotent. nc.flush(5s). [traces-to: TPRD-§7.2-close]"""
        ...

# --- 5.3 Consumer ---
class DeliverPolicy(Enum):
    ALL = "all"
    LAST = "last"
    NEW = "new"
    BY_START_SEQUENCE = "by_start_sequence"
    BY_START_TIME = "by_start_time"

@dataclass
class ConsumerConfig:
    """[traces-to: TPRD-§7.3-ConsumerConfig]
    Hard-coded: ack_policy=AckExplicitPolicy, durable=name (always durable).

    __post_init__ validation (CONV-5 fix, D3 iter 3): non-empty stream/name,
    durable name regex, non-negative timing knobs, filter-subject regex.
    Defaults (ack_wait=0, max_deliver=0, max_ack_pending=0) are sentinels:
    impl substitutes the documented defaults at consumer-creation time, so
    `0` is permitted here. Strictly negative values are rejected.
    """
    stream: str
    name: str
    filter_subjects: list[str] = field(default_factory=list)
    ack_wait: float = 30.0       # seconds; applied if 0
    max_deliver: int = 5         # applied if <= 0
    max_ack_pending: int = 1000  # applied if <= 0
    deliver_policy: DeliverPolicy = DeliverPolicy.ALL
    description: str = ""
    metadata: dict[str, str] = field(default_factory=dict)

    def __post_init__(self) -> None:
        if not self.stream or not _STREAM_NAME_REGEX.match(self.stream):
            raise ValidationError(
                f"ConsumerConfig.stream must be non-empty and match {_STREAM_NAME_REGEX.pattern!r}; got {self.stream!r}"
            )
        if not self.name or not _CONSUMER_NAME_REGEX.match(self.name):
            raise ValidationError(
                f"ConsumerConfig.name must be non-empty and match {_CONSUMER_NAME_REGEX.pattern!r}; got {self.name!r}"
            )
        for s in self.filter_subjects:
            if not _SUBJECT_REGEX.match(s):
                raise ValidationError(
                    f"ConsumerConfig.filter_subjects entry {s!r} must match {_SUBJECT_REGEX.pattern!r}"
                )
        if self.ack_wait < 0:
            raise ValidationError(f"ConsumerConfig.ack_wait must be >= 0; got {self.ack_wait}")
        if self.max_deliver < -1:
            raise ValidationError(
                f"ConsumerConfig.max_deliver must be >= -1 (-1 = unlimited); got {self.max_deliver}"
            )
        if self.max_ack_pending < 0:
            raise ValidationError(
                f"ConsumerConfig.max_ack_pending must be >= 0; got {self.max_ack_pending}"
            )
        if len(self.description) > _MAX_DESCRIPTION_LEN:
            raise ValidationError(
                f"ConsumerConfig.description length must be <= {_MAX_DESCRIPTION_LEN}; got {len(self.description)}"
            )

@dataclass
class TenantConsumerConfig:
    """[traces-to: TPRD-§7.3-TenantConsumerConfig]
    Auto-derives:
      name = consumer_name(module, tenant_id) == f'{module}-{tenant_id}'
      filter_subjects = [f'{stream}.{tenant_id}.>'] if empty

    __post_init__ validation (CONV-5 fix, D3 iter 3): inherits ConsumerConfig
    semantics for stream / filter_subjects / ack_wait / max_deliver /
    max_ack_pending / description. Adds `tenant_id` regex check that REUSES
    the same `_TENANT_ID_REGEX` enforced by `TenantKVStore` /
    `TenantObjectStore` per TPRD §15.32 — single source of truth across the
    tenant overlays.
    """
    stream: str
    module: str
    tenant_id: str
    filter_subjects: list[str] = field(default_factory=list)
    ack_wait: float = 30.0
    max_deliver: int = 5
    max_ack_pending: int = 1000
    deliver_policy: DeliverPolicy = DeliverPolicy.ALL
    description: str = ""
    metadata: dict[str, str] = field(default_factory=dict)

    def __post_init__(self) -> None:
        if not self.stream or not _STREAM_NAME_REGEX.match(self.stream):
            raise ValidationError(
                f"TenantConsumerConfig.stream must be non-empty and match {_STREAM_NAME_REGEX.pattern!r}; got {self.stream!r}"
            )
        if not self.module or not _CONSUMER_NAME_REGEX.match(self.module):
            raise ValidationError(
                f"TenantConsumerConfig.module must be non-empty and match {_CONSUMER_NAME_REGEX.pattern!r}; got {self.module!r}"
            )
        # Reuse the same regex enforced by TenantKVStore / TenantObjectStore
        # per TPRD §15.32 — keep tenant_id rules consistent across overlays.
        if not self.tenant_id or not _TENANT_ID_REGEX.match(self.tenant_id):
            raise ValidationError(
                f"TenantConsumerConfig.tenant_id must be non-empty and match {_TENANT_ID_REGEX.pattern!r}; got {self.tenant_id!r}"
            )
        if len(self.tenant_id) > MaxTenantIDLength:
            raise ValidationError(
                f"TenantConsumerConfig.tenant_id length must be <= {MaxTenantIDLength}; got {len(self.tenant_id)}"
            )
        for s in self.filter_subjects:
            if not _SUBJECT_REGEX.match(s):
                raise ValidationError(
                    f"TenantConsumerConfig.filter_subjects entry {s!r} must match {_SUBJECT_REGEX.pattern!r}"
                )
        if self.ack_wait < 0:
            raise ValidationError(f"TenantConsumerConfig.ack_wait must be >= 0; got {self.ack_wait}")
        if self.max_deliver < -1:
            raise ValidationError(
                f"TenantConsumerConfig.max_deliver must be >= -1 (-1 = unlimited); got {self.max_deliver}"
            )
        if self.max_ack_pending < 0:
            raise ValidationError(
                f"TenantConsumerConfig.max_ack_pending must be >= 0; got {self.max_ack_pending}"
            )
        if len(self.description) > _MAX_DESCRIPTION_LEN:
            raise ValidationError(
                f"TenantConsumerConfig.description length must be <= {_MAX_DESCRIPTION_LEN}; got {len(self.description)}"
            )

JsMessageHandler = Callable[[Context, "JsMsg"], Awaitable[None]]

class JsMsg(Protocol):
    """JetStream message + ack/nak/term [traces-to: TPRD-§7.3]"""
    subject: str
    data: bytes
    headers: dict[str, str] | None
    metadata: Any  # nats.js.api.MsgMetadata
    async def ack(self) -> None: ...
    async def nak(self, delay: float | None = None) -> None: ...
    async def term(self) -> None: ...
    async def in_progress(self) -> None: ...

@dataclass(frozen=True, slots=True)
class MessageBatch:
    """Result of fetch / fetch_no_wait. [traces-to: TPRD-§7.3]"""
    messages: list[JsMsg]
    consumer: str
    stream: str

class Consumer:
    """[traces-to: TPRD-§7.3-Consumer]
    [constraint: p50_dispatch <= 35us | bench/bench_jetstream_consumer_dispatch]

    Constructor accepts an optional async `on_error` hook (see __init__).
    Default behavior MIRRORS Go (silent log + return on dispatch errors);
    callers who want error surfacing opt-in via the hook (no API break).
    """
    def __init__(
        self,
        *,
        on_error: Callable[[BaseException], Awaitable[None]] | None = None,
    ) -> None:
        """Concrete construction is via `await create_consumer(js, cfg)` /
        `await create_tenant_consumer(js, cfg)` / `await get_consumer(...)`.
        Direct ctor call accepts only the optional `on_error` hook.

        Args:
            on_error: optional async callback invoked from the dispatch loop
                when ack/nak fails or handler raises. Default `None` preserves
                Go SDK behavior (silent WARN log + return; errors NEVER
                propagate to caller). Set the hook (or call
                `set_error_handler(cb)` post-construction) to opt in to
                error surfacing without changing the public method signatures.

                The hook MUST NOT raise — if it does, the exception is
                swallowed with a single `log.exception` (avoids dispatch
                recursion).

        [traces-to: TPRD-§7.3-Consumer-init]
        """
        ...

    def set_error_handler(
        self,
        cb: Callable[[BaseException], Awaitable[None]] | None,
    ) -> None:
        """Replace or clear the on_error hook post-construction. Pass None to
        revert to Go-default silent behavior.
        [traces-to: TPRD-§7.3-set-error-handler]
        """
        ...

    def name(self) -> str: ...
    def stream(self) -> str: ...
    async def info(self) -> Any: ...
    async def start(self, handler: JsMessageHandler) -> None:
        """Dispatch loop per §7.3:
          0. Per delivered msg: span 'jetstream.receive' attrs (TPRD §15.28):
                messaging.system='nats'
                messaging.destination=<msg.subject>
                messaging.operation='receive'
                messaging.operation.name='process'
          1. ctx.cancelled → msg.nak; if Nak fails: WARN 'consumer: nak failed
             on context cancellation' with consumer, err; if on_error hook is
             set, also `await on_error(exc)` before the WARN. Return.
          2. Call handler(ctx, msg).
          3. On raise → msg.nak; if Nak fails: WARN 'consumer: nak failed';
             on_error hook fired same as (1).
          4. On ok → msg.ack; if Ack fails: WARN 'consumer: ack failed';
             on_error hook fired same as (1).
        Underlying NATS lib invokes callback CONCURRENTLY per delivered msg
        (bounded by MaxAckPending=1000 default). Handler MUST be concurrent-safe.
        Hook errors are swallowed via log.exception (no dispatch recursion).
        [traces-to: TPRD-§7.3-start §15.28]
        """
        ...

    def stop(self) -> None:
        """Idempotent. start() after stop() → ErrClosed (Python sentinel,
        not Go's plain string). [traces-to: TPRD-§7.3-stop]
        """
        ...

    async def delete(self) -> None:
        """stop() + js.delete_consumer. [traces-to: TPRD-§7.3-delete]"""
        ...

    async def fetch(self, batch: int, *, timeout: float = 30.0, heartbeat: float = 5.0) -> MessageBatch:
        """[traces-to: TPRD-§7.3-fetch]"""
        ...

    async def fetch_no_wait(self, batch: int) -> MessageBatch:
        """[traces-to: TPRD-§7.3-fetch-no-wait]"""
        ...

    async def next(self, *, timeout: float = 30.0) -> JsMsg:
        """Fetch one message; block up to `timeout` seconds.

        Raises:
            ErrNoMessages: empty-queue case (Python-idiomatic translation of
                Go's plain-string `errors.New("no messages available")` — see
                ErrNoMessages docstring in events.utils). The wire-API
                behavior matches Go (caller knows "no messages" happened);
                the only change is the catch surface is now a typed
                EventsError subtype instead of a ValueError.
            EventsError: other JetStream / connection failures.

        [traces-to: TPRD-§7.3-next]
        """
        ...

