# Pool  (Â§5.1, Â§5.2)
# ---------------------------------------------------------------------------


class Pool(Generic[T]):
    """Bounded async resource pool over a caller-supplied resource type ``T``.

    Construction: ``Pool(config)``. The pool itself implements the async
    context-manager protocol (``__aenter__`` returns ``self``; ``__aexit__``
    calls :meth:`aclose`), so the canonical use is::

        async with Pool(config) as pool:
            async with pool.acquire(timeout=5.0) as resource:
                await use(resource)

    All blocking I/O methods are coroutines; ``stats`` and ``try_acquire``
    are synchronous (no I/O). Cancellation safety: a coroutine cancelled
    while inside :meth:`acquire` propagates ``asyncio.CancelledError`` and
    leaves no orphaned slot â€” proven by ``tests/unit/test_cancellation.py``.

    [traces-to: TPRD-5.1-Pool]
    """

    def __init__(self, config: PoolConfig[T]) -> None:
        """Construct a pool.

        Raises:
            ConfigError: ``config.max_size <= 0`` or
                ``config.on_create is None``.

        [traces-to: TPRD-6-CONFIG-VALIDATION]
        """
        ...

    # ------- async context manager protocol (TPRD Â§15 Q3) ----------

    async def __aenter__(self) -> Pool[T]: ...

    async def __aexit__(
        self,
        exc_type: type[BaseException] | None,
        exc: BaseException | None,
        tb: TracebackType | None,
    ) -> None: ...

    # ------- public API -------------------------------------------

    def acquire(self, *, timeout: float | None = None) -> AcquiredResource[T]:
        """Acquire a resource via async context manager.

        The returned :class:`AcquiredResource` is an async-context-manager
        that, on ``__aenter__``, awaits a free slot (subject to ``timeout``)
        and yields the resource. On ``__aexit__`` it returns the resource
        to the pool (invoking ``on_reset`` if configured).

        Args:
            timeout: Maximum seconds to wait for a free slot. ``None`` waits
                indefinitely. ``0.0`` is equivalent to a non-blocking probe
                (raises ``asyncio.TimeoutError`` if no slot is immediately
                available).

        Returns:
            An :class:`AcquiredResource` ready for ``async with``.

        Raises:
            asyncio.TimeoutError: ``timeout`` elapsed before a slot freed.
            asyncio.CancelledError: awaiting task was cancelled.
            PoolClosedError: :meth:`aclose` has been called.
            ResourceCreationError: ``on_create`` raised; ``__cause__`` is
                the underlying user exception.

        [traces-to: TPRD-5.2-acquire]
        """
        ...

    async def acquire_resource(self, *, timeout: float | None = None) -> T:
        """Acquire a resource WITHOUT context-manager wrapping (power user).

        The caller assumes full responsibility for releasing the resource
        via :meth:`release`. Failing to release leaks the slot until the
        pool is closed.

        Use only when the resource lifetime spans coroutines and
        ``async with`` is structurally impossible. Otherwise prefer
        :meth:`acquire`.

        Args:
            timeout: see :meth:`acquire`.

        Returns:
            The pooled resource of type ``T``.

        Raises:
            asyncio.TimeoutError, asyncio.CancelledError,
            PoolClosedError, ResourceCreationError â€” see :meth:`acquire`.

        [traces-to: TPRD-5.2-acquire_resource]
        """
        ...

    def try_acquire(self) -> T:
        """Synchronous, non-blocking acquire.

        Returns immediately on success; raises :class:`PoolEmptyError` if
        no slot is available. Raises :class:`ConfigError` if the pool's
        ``on_create`` is async (sync API cannot await).

        Returns:
            The pooled resource of type ``T``.

        Raises:
            PoolEmptyError: No idle slot AND pool already at ``max_size``.
            PoolClosedError: :meth:`aclose` has been called.
            ConfigError: ``on_create`` is asynchronous; use
                :meth:`acquire_resource` instead.

        [traces-to: TPRD-5.2-try_acquire]
        """
        ...

    async def release(self, resource: T) -> None:
        """Return a resource acquired via :meth:`acquire_resource`
        or :meth:`try_acquire` back to the pool.

        Calls ``on_reset`` if configured. If ``on_reset`` raises, the
        resource is destroyed via ``on_destroy`` and the slot is freed.

        Idempotent only on the same instance: calling ``release`` twice
        for the same resource is a programming error and raises
        ``RuntimeError`` (caught at the boundary in async-with sites).

        Args:
            resource: The exact object returned by an earlier acquire.

        Raises:
            PoolClosedError: pool is closed (resource will still be
                ``on_destroy``'d on a best-effort basis).
            RuntimeError: double-release detected.

        [traces-to: TPRD-5.2-release]
        """
        ...

    async def aclose(self, *, timeout: float | None = None) -> None:
        """Graceful shutdown.

        1. Pool transitions to ``closing`` â€” all subsequent acquire calls
           raise :class:`PoolClosedError` immediately.
        2. Awaits up to ``timeout`` seconds for outstanding ``in_use``
           resources to be released.
        3. On timeout, parked acquirers receive ``CancelledError``.
        4. All idle resources are destroyed (``on_destroy`` invoked
           best-effort).
        5. Idempotent: a second :meth:`aclose` call is a no-op.

        Args:
            timeout: Maximum seconds to wait for outstanding resources
                to drain. ``None`` waits indefinitely.

        [traces-to: TPRD-5.2-aclose]
        """
        ...

    def stats(self) -> PoolStats:
        """Return an immutable snapshot of pool state.

        Cheap (no awaits, no I/O); safe to call from any coroutine on the
        owning event loop. NOT safe across processes.

        [traces-to: TPRD-5.2-stats]
        """
        ...
