class AcquiredResource(Generic[T]):
    """Async context manager yielded by :meth:`Pool.acquire`.

    Not user-constructed. ``__aenter__`` returns the underlying ``T``; the
    matched ``__aexit__`` releases the resource even if the caller's body
    raises. The instance is single-use â€” re-entering after exit raises
    ``RuntimeError``.

    [traces-to: TPRD-5.3-AcquiredResource]
    """

    async def __aenter__(self) -> T: ...

    async def __aexit__(
        self,
        exc_type: type[BaseException] | None,
        exc: BaseException | None,
        tb: TracebackType | None,
    ) -> None: ...


