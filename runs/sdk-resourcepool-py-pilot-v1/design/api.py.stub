class PoolError(Exception):
    """Base class for every error raised by motadata_py_sdk.resourcepool.

    Callers may catch :class:`PoolError` to handle every pool-specific failure
    in one branch. Sub-classes are sentinel types â€” they carry no extra fields
    beyond the inherited ``args``.

    [traces-to: TPRD-5.4-PoolError]
    """


class PoolClosedError(PoolError):
    """Raised when ``acquire`` / ``acquire_resource`` / ``try_acquire`` /
    ``release`` is called on a pool that has already been ``aclose``d.

    [traces-to: TPRD-5.4-PoolClosedError]
    """


class PoolEmptyError(PoolError):
    """Raised by :meth:`Pool.try_acquire` when no slot is currently available
    and the call is non-blocking.

    [traces-to: TPRD-5.4-PoolEmptyError]
    """


class ConfigError(PoolError):
    """Raised by :class:`Pool.__init__` when the supplied :class:`PoolConfig`
    is invalid (``max_size <= 0``, missing ``on_create``, etc.) or by
    :meth:`Pool.try_acquire` when invoked against a pool whose ``on_create``
    hook is asynchronous (sync API cannot await).

    [traces-to: TPRD-5.4-ConfigError]
    """


class ResourceCreationError(PoolError):
    """Raised by :meth:`Pool.acquire` / :meth:`Pool.acquire_resource` when the
    user-supplied ``on_create`` hook itself raised. The original exception is
    preserved as ``__cause__`` (PEP 3134).

    [traces-to: TPRD-7-HOOK-FAILURE]
    """


