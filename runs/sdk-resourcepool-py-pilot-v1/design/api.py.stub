@dataclass(frozen=True, slots=True)
class PoolConfig(Generic[T]):
    """Immutable, frozen pool configuration.

    Constructed once and passed to :class:`Pool`; cannot be mutated afterward.
    Hook callables may be plain ``def`` or ``async def`` â€” :class:`Pool`
    detects with ``asyncio.iscoroutinefunction`` and awaits as required.

    Attributes:
        max_size: Hard upper bound on resources lazily created by the pool.
            MUST be ``> 0`` (else ``ConfigError``).
        on_create: Factory invoked the first time a slot is filled.
            Called synchronously OR awaited; both are supported.
        on_reset: Optional. Invoked on :meth:`Pool.release` before the
            resource is returned to the idle set. Failure â†’ resource is
            destroyed via ``on_destroy`` and the slot is freed for the next
            acquirer (which creates a fresh resource).
        on_destroy: Optional. Invoked when a resource is permanently retired
            (on_reset failure, pool close, on_create failure cleanup).
            Failure is logged at WARN; the slot is still freed (best-effort
            destroy mirrors Go pool semantics).
        name: Human-readable identifier surfaced in log records and
            (future) OTel attributes. Empty string is coerced to
            ``"resourcepool"``; never raises.

    [traces-to: TPRD-5.1-PoolConfig]
    """

    max_size: int
    on_create: Callable[[], T] | Callable[[], Awaitable[T]]
    on_reset: Callable[[T], None] | Callable[[T], Awaitable[None]] | None = None
    on_destroy: Callable[[T], None] | Callable[[T], Awaitable[None]] | None = None
    name: str = "resourcepool"


@dataclass(frozen=True, slots=True)
class PoolStats:
    """Frozen point-in-time snapshot of pool state.

    Returned by :meth:`Pool.stats`. Produced by copying primitive counters
    under the pool's internal lock; never holds a reference to live state.

    Attributes:
        created: Total resources ever instantiated by ``on_create``
            (monotonic-non-decreasing for the pool's lifetime).
        in_use: Resources currently checked out (``acquired - released``).
        idle: Resources currently sitting in the pool, ready for
            ``acquire`` to return without invoking ``on_create``.
        waiting: Tasks currently parked inside ``acquire`` waiting for a
            slot to free; ``0`` whenever ``in_use < max_size``.
        closed: ``True`` after :meth:`Pool.aclose` has fully completed.

    Invariant: ``in_use + idle <= max_size`` and ``in_use <= created``.

    [traces-to: TPRD-5.3-PoolStats]
    """

    created: int
    in_use: int
    idle: int
    waiting: int
    closed: bool


