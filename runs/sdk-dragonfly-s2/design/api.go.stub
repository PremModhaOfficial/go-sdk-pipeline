// ---------------------------------------------------------------------------
// Pool-stats scraper — poolstats.go
// ---------------------------------------------------------------------------

// poolStatsScraper is an internal goroutine that periodically reads rdb.PoolStats()
// and emits gauges via motadatagosdk/otel/metrics. Owned by Cache; lifecycle is
// Start()/Stop() paired with New()/Close(). [traces-to: TPRD-§8.2-poolstats]
type poolStatsScraper struct {
	rdb      *redis.Client
	interval time.Duration
	done     chan struct{}
}

// unused-symbol reference guard (keeps go vet happy on stub; removed in Phase 2).
var _ = func() *TLSConfig { var t tls.Config; _ = t; return &TLSConfig{} }
