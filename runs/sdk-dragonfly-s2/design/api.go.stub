// Cache is the Dragonfly L2 cache client. Safe for concurrent use.
// [traces-to: TPRD-§5.1 TPRD-§8]
type Cache struct {
	rdb     *redis.Client
	cfg     Config
	scraper *poolStatsScraper
}

// Compile-time interface assertions (G43). [traces-to: TPRD-design-G43]
var _ = (*Cache)(nil)

// New constructs a Cache from the supplied options. Validates config, dials
// lazily (first op establishes conn; Ping forces it). [traces-to: TPRD-§5.1-New]
func New(opts ...Option) (*Cache, error) {
	return nil, nil
}

// Ping verifies server reachability. [traces-to: TPRD-§5.1-Ping]
func (c *Cache) Ping(ctx context.Context) error { return nil }

// Close shuts down the pool and stops the pool-stats scraper.
// Idempotent. [traces-to: TPRD-§5.1-Close]
func (c *Cache) Close() error { return nil }

