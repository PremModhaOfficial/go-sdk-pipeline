{
  "pipeline_version": "0.6.0",
  "target_sdk_dir_env": "SDK_TARGET_DIR",
  "phase_budgets": {
    "intake": {
      "tokens": 150000,
      "wall_clock_sec": 1200
    },
    "design": {
      "tokens": 500000,
      "wall_clock_sec": 3600
    },
    "implementation": {
      "tokens": 1000000,
      "wall_clock_sec": 7200
    },
    "testing": {
      "tokens": 500000,
      "wall_clock_sec": 3600
    },
    "feedback": {
      "tokens": 200000,
      "wall_clock_sec": 1800
    }
  },
  "safety_caps": {
    "prompt_patches_per_run": 10,
    "existing_skill_patches_per_run": 3,
    "new_skills_per_run": 0,
    "new_guardrails_per_run": 0,
    "new_agents_per_run": 0,
    "per_issue_max_retries": 5,
    "global_max_iterations": 10,
    "stuck_threshold": 2,
    "baseline_reset_every_n_runs": 5,
    "_note": "new_skills/guardrails/agents are human-authored via PR only; pipeline runtime caps are 0"
  },
  "hitl_gate_timeouts_hours": {
    "H0_target_dir": 0,
    "H1_tprd": 24,
    "H4_breaking": 48,
    "H5_design": 24,
    "H6_dep_vet": 12,
    "H7_impl_diff": 24,
    "H7b_mode_c_diff": 48,
    "H8_bench": 12,
    "H9_testing": 24,
    "H10_merge": 72,
    "_note": "H2 (skills) and H3 (agents) removed with Phase -1; H9 repurposed from skill-major to testing sign-off"
  },
  "regression_gates": {
    "bench_hot_path_pct": 5,
    "bench_shared_pct": 10,
    "coverage_min_new_pkg": 90,
    "coverage_min_existing_pkg_delta": 0
  },
  "permissions": {
    "allow": [
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(gofmt:*)",
      "Bash(staticcheck:*)",
      "Bash(govulncheck:*)",
      "Bash(osv-scanner:*)",
      "Bash(benchstat:*)",
      "Bash(pytest:*)",
      "Bash(mypy:*)",
      "Bash(ruff:*)",
      "Bash(bandit:*)",
      "Bash(pip-audit:*)",
      "Bash(safety:*)",
      "Bash(python -m build:*)",
      "Bash(python -m pytest:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git rev-parse:*)",
      "Bash(git merge-base:*)",
      "Bash(jq:*)",
      "Bash(sha256sum:*)",
      "Bash(find:*)",
      "Read(*)",
      "Write(runs/**)",
      "Write(.claude/**)",
      "Write(baselines/**)",
      "Write(evolution/**)",
      "Write(state/**)"
    ],
    "deny_write_outside_target_or_runs": true,
    "never_commit": true,
    "never_push": true
  },
  "advisory_hooks": {
    "note": "Advisory only — these are conceptual invariants enforced by agent prompts + guardrails (G07, G01), NOT Claude Code runtime hooks. Real Claude Code hooks (matcher+hooks array schema) can be added later if needed.",
    "pre_write": "verify path within SDK_TARGET_DIR or runs/ or pipeline repo",
    "post_bash": "append to runs/<run-id>/decision-log.jsonl as event entry"
  },
  "license_allowlist": [
    "MIT",
    "Apache-2.0",
    "BSD-3-Clause",
    "BSD-2-Clause",
    "ISC",
    "0BSD",
    "MPL-2.0"
  ],
  "skill_drift_check_every_n_runs": 10
}
